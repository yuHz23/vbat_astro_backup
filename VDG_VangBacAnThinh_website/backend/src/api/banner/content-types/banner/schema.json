{
  "kind": "collectionType",
  "collectionName": "banners",
  "info": {
    "singularName": "banner",
    "pluralName": "banners",
    "displayName": "Banner",
    "description": "Homepage and promotional banners"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "mobileImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "link": {
      "type": "string"
    },
    "position": {
      "type": "enumeration",
      "enum": ["hero", "sub", "promo"],
      "default": "hero",
      "required": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
