<!-- Live Price Ticker - marquee right to left -->
<div class="bg-primary text-white text-xs py-2 overflow-hidden relative z-40 border-b border-white/10" x-data="{
  items: [],
  async init() {
    try {
      const res = await (await fetch('/api/gold-prices?filters[isActive][$eq]=true&sort[0]=sortOrder:asc&pagination[pageSize]=20')).json();
      if (res.data && res.data.length > 0) {
        this.items = res.data.map(d => ({
          name: d.goldName || d.goldType,
          buy: d.buyPrice,
          sell: d.sellPrice,
          unit: d.unit || 'VNĐ/lượng',
        }));
      }
    } catch(e) {}
  },
  fmt(n) { return new Intl.NumberFormat('en-US').format(n); }
}">
  <div class="flex items-center" x-show="items.length > 0">
    <div class="ticker-track flex items-center gap-0 whitespace-nowrap">
      <!-- Duplicate content for seamless loop -->
      <template x-for="pass in [0, 1]" :key="pass">
        <div class="flex items-center gap-0 shrink-0">
          <template x-for="(item, i) in items" :key="pass + '-' + i">
            <div class="flex items-center gap-2 px-5 border-r border-white/20">
              <span class="font-bold text-accent" x-text="item.name"></span>
              <span class="text-gray-300">MV:</span>
              <span class="font-semibold text-green-300" x-text="fmt(item.buy)"></span>
              <span class="text-gray-400">|</span>
              <span class="text-gray-300">BR:</span>
              <span class="font-semibold text-red-300" x-text="fmt(item.sell)"></span>
            </div>
          </template>
        </div>
      </template>
    </div>
  </div>
</div>

<style>
  .ticker-track {
    animation: ticker-scroll 120s linear infinite;
  }
  .ticker-track:hover {
    animation-play-state: paused;
  }
  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
