<!-- Header (Home variant) -->
<header x-data="header" class="bg-[#1e2a3a] text-white sticky top-0 z-50">
  <div class="max-w-[1200px] mx-auto px-8 h-[64px] flex items-center justify-between">

    <!-- Left: Logo + Nav -->
    <div class="flex items-center">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img src="/logo-header.png" alt="Vàng An Thịnh" class="h-10 object-contain" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center ml-20 gap-14 text-[16px] font-semibold tracking-[0.15em] uppercase h-[64px]">
        <a href="/san-pham.html" class="text-white/90 hover:text-white transition-colors h-full flex items-center border-b-[3px] border-transparent hover:border-white">Vàng</a>
        <a href="/san-pham-bac.html" class="text-white/90 hover:text-white transition-colors h-full flex items-center border-b-[3px] border-transparent hover:border-white">Bạc</a>

        <!-- Bảng Giá Dropdown -->
        <div class="relative group/banggia h-full flex items-center">
          <button class="text-white/90 hover:text-white transition-colors h-full flex items-center border-b-[3px] border-transparent group-hover/banggia:border-white font-semibold tracking-[0.15em] uppercase">
            Bảng Giá
          </button>
          <div
            class="invisible opacity-0 group-hover/banggia:visible group-hover/banggia:opacity-100 transition-all duration-150 absolute left-1/2 -translate-x-1/2 top-full w-[480px] bg-white rounded-xl shadow-2xl border border-gray-100 p-5 z-50">
            <div class="grid grid-cols-2 gap-4 text-left">
              <a href="/gia-vang.html"
                class="flex flex-col p-4 rounded-lg hover:bg-gray-50 transition-colors group border border-gray-100">
                <div class="flex items-center gap-2 mb-2">
                  <svg class="w-5 h-5 shrink-0 text-yellow-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2z"/></svg>
                  <h3 class="text-sm font-extrabold text-gray-900 uppercase tracking-wide">Bảng Giá Vàng</h3>
                </div>
                <p class="text-xs text-gray-500 mb-3 leading-relaxed normal-case flex-1">Cập nhật giá Vàng miếng, Vàng 999,9 tại Vàng An Thịnh theo thời gian thực</p>
                <span class="inline-block bg-yellow-400 text-yellow-900 text-xs font-bold px-4 py-1.5 rounded-full normal-case self-start">Xem chi tiết</span>
              </a>
              <a href="/gia-bac.html"
                class="flex flex-col p-4 rounded-lg hover:bg-gray-50 transition-colors group border border-gray-100">
                <div class="flex items-center gap-2 mb-2">
                  <svg class="w-5 h-5 shrink-0 text-gray-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2z"/></svg>
                  <h3 class="text-sm font-extrabold text-gray-900 uppercase tracking-wide">Bảng Giá Bạc</h3>
                </div>
                <p class="text-xs text-gray-500 mb-3 leading-relaxed normal-case flex-1">Cập nhật giá Bạc miếng, Bạc thỏi, Bạc mỹ nghệ tại Vàng An Thịnh theo thời gian thực</p>
                <span class="inline-block bg-gray-200 text-gray-700 text-xs font-bold px-4 py-1.5 rounded-full normal-case self-start">Xem chi tiết</span>
              </a>
            </div>
          </div>
        </div>

        <a href="/he-thong-cua-hang.html" class="text-white/90 hover:text-white transition-colors h-full flex items-center border-b-[3px] border-transparent hover:border-white">Cửa hàng</a>
        <a x-show="$store.auth.isAdmin" x-cloak :href="window.location.hostname === 'localhost' || /^\d+\.\d+\.\d+\.\d+$/.test(window.location.hostname) ? window.location.protocol + '//' + window.location.hostname + ':3001' : window.location.protocol + '//admin.' + window.location.hostname" class="text-accent hover:text-white transition-colors h-full flex items-center border-b-[3px] border-transparent hover:border-accent font-semibold">Admin</a>
      </nav>
    </div>

    <!-- Right: Icons -->
    <div class="flex items-center gap-5">
      <button @click="$store.ui.toggleSearch()" class="text-white/80 hover:text-white transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>
      <a href="/tai-khoan.html" class="text-white/80 hover:text-white transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </a>
      <button @click="$store.cart.toggle()" class="text-white/80 hover:text-white transition-colors relative">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        <span x-show="$store.cart.count > 0" x-text="$store.cart.count"
          class="absolute -top-2 -right-2 bg-pq-red text-white text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center"></span>
      </button>
      <button @click="$store.ui.toggleMobileMenu()" class="lg:hidden text-white hover:text-accent transition-colors">
        <svg x-show="!$store.ui.mobileMenuOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg x-show="$store.ui.mobileMenuOpen" x-cloak class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>
</header>
