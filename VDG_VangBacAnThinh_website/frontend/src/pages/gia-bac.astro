---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Giá Bạc Hôm Nay - Vàng An Thịnh"
  description="Bảng giá bạc An Thịnh cập nhật liên tục. Giá bạc mới nhất hôm nay."
  variant="home"
  showTicker={true}
>
  <main x-data="goldPricePage('Bạc')" class="bg-white min-h-screen">

    <div class="max-w-7xl mx-auto px-4 py-6">

      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-500 mb-6 flex items-center gap-1.5">
        <a href="/" class="hover:text-gray-800 transition-colors">Trang chủ</a>
        <span class="text-gray-300">/</span>
        <span class="font-semibold text-gray-800">Bảng giá bạc</span>
      </nav>

      <!-- ===== CHART SECTION ===== -->
      <div class="mb-10">

        <!-- Chart Title -->
        <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-5 uppercase tracking-wide">
          Biểu đồ giá bạc tại Vàng An Thịnh
        </h1>

        <!-- Chart Controls Row -->
        <div class="flex flex-wrap items-end gap-x-6 gap-y-3 mb-4">
          <!-- Silver Type Dropdown -->
          <div class="flex items-center gap-3">
            <span class="text-sm text-gray-600 whitespace-nowrap">Biểu<br>đồ giá</span>
            <div class="relative">
              <select x-model="selectedType"
                class="appearance-none border border-gray-300 rounded px-4 py-2 pr-8 text-[14px] font-semibold text-gray-800 focus:outline-none focus:border-gray-500 cursor-pointer bg-white min-w-[200px]">
                <option value="Bạc">Bạc mỹ nghệ 999</option>
                <option value="BAC-MIEN">Bạc miếng 999</option>
                <option value="BAC-NHAN">Bạc nhẫn tròn trơn</option>
                <option value="Bạc thỏi">Bạc thỏi Phú Quý</option>
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-500">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd"
                    d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                    clip-rule="evenodd" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Date Range -->
          <div class="flex items-center gap-3 text-sm text-gray-600">
            <span class="whitespace-nowrap">Từ<br>ngày</span>
            <input type="date"
              class="border border-gray-300 rounded px-3 py-2 text-sm text-gray-700 focus:outline-none focus:border-gray-500 bg-white cursor-pointer min-w-[140px]"
              x-model="chartDateFrom" />
            <span class="whitespace-nowrap">đến<br>ngày</span>
            <input type="date"
              class="border border-gray-300 rounded px-3 py-2 text-sm text-gray-700 focus:outline-none focus:border-gray-500 bg-white cursor-pointer min-w-[140px]"
              x-model="chartDateTo" />
          </div>
        </div>

        <!-- Change Indicator -->
        <div class="mb-4">
          <span class="text-red-500 font-bold text-base">&#x25BC; 5.4%</span>
          <span class="text-gray-500 text-sm ml-1">1 tháng qua</span>
        </div>

        <!-- Large Price Display -->
        <div class="flex flex-wrap gap-8 mb-5">
          <div>
            <div class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-1">Giá mua vào</div>
            <div class="text-3xl md:text-4xl font-extrabold text-pq-red tabular-nums"
              x-text="!loadingHistories && currentSilverMV ? new Intl.NumberFormat('vi-VN').format(currentSilverMV) : '---'">
            </div>
          </div>
          <div>
            <div class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-1">Giá bán ra</div>
            <div class="text-3xl md:text-4xl font-extrabold text-[#008080] tabular-nums"
              x-text="!loadingHistories && currentSilverBR ? new Intl.NumberFormat('vi-VN').format(currentSilverBR) : '---'">
            </div>
          </div>
        </div>

        <!-- Time Range Buttons + Legend + Unit Toggle -->
        <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
          <div class="flex items-center gap-3 flex-wrap">
            <div class="flex items-center gap-1">
              <template x-for="range in ['1D','7D','1M','3M','1Y']" :key="range">
                <button @click="selectedTimeRange = range"
                  :class="selectedTimeRange === range ? 'bg-gray-800 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'"
                  class="px-3 py-1.5 rounded text-xs font-bold transition-colors" x-text="range"></button>
              </template>
            </div>
            <div class="flex items-center gap-4 text-xs text-gray-500 ml-2">
              <span class="flex items-center gap-1.5">
                <span class="w-6 h-0.5 bg-red-500 inline-block rounded"></span>
                Mua vào
              </span>
              <span class="flex items-center gap-1.5">
                <span class="w-6 h-0.5 bg-green-600 inline-block rounded"></span>
                Bán ra
              </span>
            </div>
          </div>
          <div class="flex border border-gray-300 rounded overflow-hidden text-xs font-semibold">
            <button class="px-4 py-1.5 bg-white text-gray-600 hover:bg-gray-50 transition-colors">Chỉ</button>
            <button class="px-4 py-1.5 bg-gray-800 text-white">Lượng</button>
          </div>
        </div>

        <!-- Chart Area -->
        <div class="border border-gray-200 rounded bg-white h-[360px] md:h-[420px] relative">
          <div x-show="loadingHistories" class="absolute inset-0 flex items-center justify-center bg-white/80 z-10">
            <svg class="w-8 h-8 animate-spin text-pq-red" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </div>
          <canvas id="silverChart" class="w-full h-full"></canvas>
        </div>
      </div>

      <!-- ===== PRICE TABLE SECTION ===== -->
      <div>
        <h2 class="text-xl md:text-2xl font-extrabold text-gray-900 uppercase tracking-wide mb-1">
          Bảng giá bạc hôm nay tại Vàng An Thịnh
        </h2>
        <div class="text-xs text-gray-500 mb-4" x-text="lastUpdated ? lastUpdated : 'Đang cập nhật...'"></div>

        <div x-show="loading" class="text-center py-16">
          <svg class="w-8 h-8 mx-auto animate-spin text-pq-red mb-3" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <p class="text-gray-500 text-sm">Đang tải dữ liệu...</p>
        </div>

        <div x-show="!loading" x-cloak class="overflow-x-auto border border-gray-200 rounded">
          <table class="w-full text-left border-collapse min-w-[600px]">
            <thead>
              <tr style="background-color: #1e3a5f;">
                <th class="py-3.5 px-5 text-white text-sm font-bold uppercase tracking-wider">Loại bạc</th>
                <th class="py-3.5 px-5 text-white text-sm font-bold uppercase tracking-wider text-center w-40">
                  Đơn vị
                </th>
                <th class="py-3.5 px-5 text-white text-sm font-bold uppercase tracking-wider text-center w-40">
                  Mua vào<br><span class="font-normal text-blue-200 text-[11px] normal-case">(Vnđ/lượng)</span>
                </th>
                <th class="py-3.5 px-5 text-white text-sm font-bold uppercase tracking-wider text-center w-40">
                  Bán ra<br><span class="font-normal text-blue-200 text-[11px] normal-case">(Vnđ/lượng)</span>
                </th>
                <th class="py-3.5 px-5 text-white text-sm font-bold text-center w-24">Thao tác</th>
              </tr>
            </thead>
            <tbody>
              <template x-if="silverPrices.length > 0">
                <tr style="background-color: #f0f4f8;">
                  <td colspan="5" class="py-2 px-5 text-xs font-bold text-gray-500 uppercase tracking-widest">
                    Bạc Thương Hiệu Vàng An Thịnh
                  </td>
                </tr>
              </template>

              <template x-for="(price, index) in silverPrices" :key="'silver-' + price.id">
                <tr :class="index % 2 === 0 ? 'bg-white' : 'bg-blue-50'"
                  class="border-b border-gray-100 hover:bg-blue-100/40 transition-colors group">
                  <td class="py-3.5 px-5 text-[14px] text-gray-800 font-medium" x-text="price.goldName"></td>
                  <td class="py-3.5 px-5 text-center text-xs text-gray-500" x-text="price.unit || 'Vnđ/lượng'"></td>
                  <td class="py-3.5 px-5 text-center">
                    <span class="text-pq-red font-bold text-[15px] tabular-nums"
                      x-text="new Intl.NumberFormat('vi-VN').format(price.buyPrice)"></span>
                    <span class="text-green-600 text-xs ml-0.5">&#x2191;</span>
                  </td>
                  <td class="py-3.5 px-5 text-center">
                    <span class="text-pq-red font-bold text-[15px] tabular-nums"
                      x-text="new Intl.NumberFormat('vi-VN').format(price.sellPrice)"></span>
                    <span class="text-green-600 text-xs ml-0.5">&#x2191;</span>
                  </td>
                  <td class="py-3.5 px-5 text-center">
                    <button @click="openEditModal(price)"
                      class="text-gray-300 hover:text-pq-red transition-colors opacity-0 group-hover:opacity-100"
                      title="Chỉnh sửa">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                      </svg>
                    </button>
                  </td>
                </tr>
              </template>

              <template x-if="silverPrices.length === 0 && !loading">
                <tr>
                  <td colspan="5" class="py-16 text-center text-gray-400 text-sm">Chưa có dữ liệu giá trong hệ thống.
                  </td>
                </tr>
              </template>
            </tbody>
          </table>
        </div>

        <div class="mt-3 text-[12px] text-gray-500 flex flex-wrap items-center gap-1.5">
          <span class="text-gray-400">&#x2022;</span>
          Đơn giá trên đã bao gồm thuế GTGT. Liên hệ
          <a href="tel:0363778889" class="text-pq-red font-semibold hover:underline">0363.778.889</a>
          để báo giá chính xác nhất.
          <span class="ml-auto text-gray-400" x-text="'Cập nhật lần cuối: ' + (lastUpdated || '...')"></span>
        </div>
      </div>

    </div>
  </main>
</Layout>
