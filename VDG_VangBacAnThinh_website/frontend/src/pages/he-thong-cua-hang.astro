---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hệ Thống Cửa Hàng - Vàng An Thịnh" description="Cửa hàng Vàng An Thịnh - Địa chỉ mua bán vàng bạc uy tín tại Hà Nội." variant="home">
  <main>

    <!-- Breadcrumb -->
    <div class="bg-white border-b">
      <div class="max-w-7xl mx-auto px-4 py-3">
        <nav class="text-sm text-gray-500">
          <a href="/" class="hover:text-accent">Trang chủ</a>
          <span class="mx-2">/</span>
          <span class="text-primary font-medium">Cửa hàng</span>
        </nav>
      </div>
    </div>

    <!-- Page Header -->
    <section class="bg-primary py-12">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h1 class="font-heading text-3xl md:text-4xl text-accent mb-3">Cửa Hàng Vàng An Thịnh</h1>
        <p class="text-text-light text-lg">Địa chỉ mua bán vàng bạc uy tín tại Hà Nội</p>
      </div>
    </section>

    <!-- Store + Map -->
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4">
        <div class="grid lg:grid-cols-2 gap-8">

          <!-- Store Info -->
          <div>
            <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
              <div class="flex items-center gap-3 mb-6">
                <img src="/logo-icon.png" alt="An Thịnh" class="w-12 h-12 rounded-full object-cover" />
                <div>
                  <h2 class="font-heading text-xl text-primary font-bold">Vàng An Thịnh</h2>
                  <p class="text-sm text-gray-500">Chi nhánh duy nhất</p>
                </div>
              </div>

              <div class="space-y-4 text-sm text-gray-600">
                <div class="flex items-start gap-3 p-3 bg-light-bg rounded-lg">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <div>
                    <p class="font-medium text-primary mb-1">Địa chỉ</p>
                    <p>Số 141P Trương Định, Phường Tương Mai, Quận Hoàng Mai, Hà Nội</p>
                  </div>
                </div>

                <div class="flex items-start gap-3 p-3 bg-light-bg rounded-lg">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <div>
                    <p class="font-medium text-primary mb-1">Hotline</p>
                    <a href="tel:0363778889" class="text-accent hover:text-accent-dark font-semibold text-lg">0363 778 889</a>
                  </div>
                </div>

                <div class="flex items-start gap-3 p-3 bg-light-bg rounded-lg">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <div>
                    <p class="font-medium text-primary mb-1">Giờ mở cửa</p>
                    <p>8:00 - 20:00 (Thứ 2 - Chủ nhật)</p>
                  </div>
                </div>

                <div class="flex items-start gap-3 p-3 bg-light-bg rounded-lg">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <div>
                    <p class="font-medium text-primary mb-1">Email</p>
                    <a href="mailto:ankhangthinh2025@gmail.com" class="text-accent hover:text-accent-dark">ankhangthinh2025@gmail.com</a>
                  </div>
                </div>
              </div>

              <!-- CTA -->
              <div class="mt-6 flex gap-3">
                <a href="https://www.google.com/maps/dir/?api=1&destination=20.9913284,105.8488338" target="_blank" rel="noopener"
                  class="flex-1 bg-accent text-white py-3 rounded-lg text-sm font-semibold text-center hover:bg-accent-dark transition-colors">
                  Chỉ đường
                </a>
                <a href="tel:0363778889"
                  class="flex-1 bg-primary text-white py-3 rounded-lg text-sm font-semibold text-center hover:bg-primary-light transition-colors">
                  Gọi ngay
                </a>
              </div>
            </div>
          </div>

          <!-- Map -->
          <div class="h-full flex flex-col">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden flex-1 min-h-[500px]">
              <iframe
                src="https://maps.google.com/maps?q=20.9913284,105.8488338&z=17&output=embed"
                width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
                referrerpolicy="no-referrer-when-downgrade">
              </iframe>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>
</Layout>
