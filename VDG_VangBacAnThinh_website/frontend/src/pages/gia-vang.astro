---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Giá Vàng Hôm Nay - Vàng An Thịnh"
  description="Bảng giá vàng An Thịnh cập nhật liên tục. Giá vàng SJC, vàng 9999, vàng trang sức mới nhất hôm nay."
  variant="home"
  showTicker={true}
>
  <main x-data="goldPricePage('SJL1L10')" class="bg-white min-h-screen">

    <div class="max-w-7xl mx-auto px-4 py-6">

      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-500 mb-6 flex items-center gap-1.5">
        <a href="/" class="hover:text-gray-800 transition-colors">Trang chủ</a>
        <span class="text-gray-300">/</span>
        <span class="font-semibold text-gray-800">Bảng giá vàng</span>
      </nav>

      <!-- ===== CHART SECTION ===== -->
      <div class="mb-10">

        <!-- Chart Title -->
        <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-5 uppercase tracking-wide">
          Biểu đồ giá vàng tại Vàng An Thịnh
        </h1>

        <!-- Chart Controls Row -->
        <div class="flex flex-wrap items-end gap-x-6 gap-y-3 mb-4">
          <!-- Gold Type Dropdown -->
          <div class="flex items-center gap-3">
            <span class="text-sm text-gray-600 whitespace-nowrap">Biểu<br>đồ giá</span>
            <div class="relative">
              <select x-model="selectedType"
                class="appearance-none border border-gray-300 rounded px-4 py-2 pr-8 text-[14px] font-semibold text-gray-800 focus:outline-none focus:border-gray-500 cursor-pointer bg-white min-w-[200px]">
                <template x-for="gt in goldTypes" :key="gt.code">
                  <option :value="gt.code" x-text="gt.name"></option>
                </template>
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-500">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd"
                    d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                    clip-rule="evenodd" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Date Range -->
          <div class="flex items-center gap-3 text-sm text-gray-600">
            <span class="whitespace-nowrap">Từ<br>ngày</span>
            <div class="relative">
              <input type="date"
                class="border border-gray-300 rounded px-3 py-2 text-sm text-gray-700 focus:outline-none focus:border-gray-500 bg-white cursor-pointer pr-8 min-w-[140px]"
                x-model="chartDateFrom" />
            </div>
            <span class="whitespace-nowrap">đến<br>ngày</span>
            <div class="relative">
              <input type="date"
                class="border border-gray-300 rounded px-3 py-2 text-sm text-gray-700 focus:outline-none focus:border-gray-500 bg-white cursor-pointer pr-8 min-w-[140px]"
                x-model="chartDateTo" />
            </div>
          </div>
        </div>

        <!-- Change Indicator -->
        <div class="mb-4">
          <span class="text-green-600 font-bold text-base">&#x25B2; 2%</span>
          <span class="text-gray-500 text-sm ml-1">1 tháng qua</span>
        </div>

        <!-- Large Price Display -->
        <div class="flex flex-wrap gap-8 mb-5">
          <div>
            <div class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-1">Giá mua vào</div>
            <div class="text-3xl md:text-4xl font-extrabold text-pq-red tabular-nums flex items-baseline gap-1"
              x-text="!loadingHistories && currentGoldMV ? new Intl.NumberFormat('vi-VN').format(chartUnit === 'chi' && selectedType !== 'XAUUSD' ? currentGoldMV / 10 : currentGoldMV) : '---'">
            </div>
          </div>
          <div>
            <div class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-1">Giá bán ra</div>
            <div class="text-3xl md:text-4xl font-extrabold text-[#008080] tabular-nums flex items-baseline gap-1"
              x-text="!loadingHistories && currentGoldBR ? new Intl.NumberFormat('vi-VN').format(chartUnit === 'chi' && selectedType !== 'XAUUSD' ? currentGoldBR / 10 : currentGoldBR) : '---'">
            </div>
          </div>
        </div>

        <!-- Time Range Buttons + Legend + Unit Toggle -->
        <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
          <!-- Left: Time Range Buttons + Legend -->
          <div class="flex items-center gap-3 flex-wrap">
            <!-- Time Range Pills -->
            <div class="flex items-center gap-1">
              <template x-for="range in ['1D','7D','1M','3M','1Y']" :key="range">
                <button @click="selectedTimeRange = range"
                  :class="selectedTimeRange === range ? 'bg-gray-800 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'"
                  class="px-3 py-1.5 rounded text-xs font-bold transition-colors" x-text="range"></button>
              </template>
            </div>
            <!-- Legend -->
            <div class="flex items-center gap-4 text-xs text-gray-500 ml-2">
              <span class="flex items-center gap-1.5">
                <span class="w-6 h-0.5 bg-red-500 inline-block rounded"></span>
                Mua vào
              </span>
              <span class="flex items-center gap-1.5">
                <span class="w-6 h-0.5 bg-green-600 inline-block rounded"></span>
                Bán ra
              </span>
            </div>
          </div>

          <!-- Right: Chỉ/Lượng toggle -->
          <div class="flex border border-gray-300 rounded overflow-hidden text-xs font-semibold">
            <button @click="chartUnit = 'chi'"
              :class="chartUnit === 'chi' ? 'bg-gray-800 text-white' : 'bg-white text-gray-600 hover:bg-gray-50'"
              class="px-4 py-1.5 transition-colors">Chỉ</button>
            <button @click="chartUnit = 'luong'"
              :class="chartUnit === 'luong' ? 'bg-gray-800 text-white' : 'bg-white text-gray-600 hover:bg-gray-50'"
              class="px-4 py-1.5 transition-colors">Lượng</button>
          </div>
        </div>

        <!-- Chart Area -->
        <div class="border border-gray-200 rounded bg-white h-[360px] md:h-[420px] relative">
          <div x-show="loadingHistories" class="absolute inset-0 flex items-center justify-center bg-white/80 z-10">
            <svg class="w-8 h-8 animate-spin text-pq-red" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </div>
          <canvas id="goldChart" class="w-full h-full"></canvas>
        </div>
      </div>

      <!-- ===== PRICE TABLE SECTION ===== -->
      <div>
        <!-- Table Title + Timestamp -->
        <div class="flex items-center gap-3 mb-4">
          <h2 class="text-xl md:text-2xl font-extrabold text-gray-900 uppercase tracking-wide">
            Bảng giá vàng hôm nay tại Vàng An Thịnh
          </h2>
          <!-- Live badge -->
          <span
            class="flex items-center gap-1 bg-green-50 border border-green-200 text-green-700 text-[11px] font-bold px-2.5 py-1 rounded-full">
            <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse inline-block"></span>
            LIVE
          </span>
        </div>
        <div class="text-xs text-gray-500 mb-4"
          x-text="lastUpdated ? 'Cập nhật: ' + lastUpdated + ' (tự động refresh mỗi 5 phút)' : 'Đang cập nhật...'">
        </div>

        <!-- Loading -->
        <div x-show="loading" class="text-center py-16">
          <svg class="w-8 h-8 mx-auto animate-spin text-pq-red mb-3" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <p class="text-gray-500 text-sm">Đang tải dữ liệu...</p>
        </div>

        <!-- Table -->
        <div x-show="!loading" x-cloak class="overflow-x-auto border border-gray-200 rounded">
          <table class="w-full text-left border-collapse min-w-[600px]">
            <thead>
              <tr style="background-color: #c0392b;">
                <th class="py-3.5 px-5 text-white text-sm font-bold uppercase tracking-wider">Loại vàng</th>
                <th class="py-3.5 px-5 text-white text-sm font-bold uppercase tracking-wider text-center w-40">
                  Mua vào<br><span class="font-normal text-red-100 text-[11px] normal-case">(Vnđ/Chỉ)</span>
                </th>
                <th class="py-3.5 px-5 text-white text-sm font-bold uppercase tracking-wider text-center w-40">
                  Bán ra<br><span class="font-normal text-red-100 text-[11px] normal-case">(Vnđ/Chỉ)</span>
                </th>
                <th class="py-3.5 px-5 text-white text-sm font-bold text-center w-24">Thao tác</th>
              </tr>
            </thead>
            <tbody>
              <!-- Gold Section Header Row -->
              <template x-if="goldPrices.length > 0">
                <tr style="background-color: #f5f5f5;">
                  <td colspan="4" class="py-2 px-5 text-xs font-bold text-gray-500 uppercase tracking-widest">
                    Vàng miếng & Trang sức
                  </td>
                </tr>
              </template>

              <template x-for="(price, index) in goldPrices" :key="'gold-' + price.goldType">
                <tr :class="index % 2 === 0 ? 'bg-white' : 'bg-red-50'"
                  class="border-b border-gray-100 hover:bg-red-100/40 transition-colors group">
                  <td class="py-3.5 px-5 text-[14px] text-gray-800 font-medium" x-text="price.goldName"></td>
                  <td class="py-3.5 px-5 text-center">
                    <span class="text-pq-red font-bold text-[15px] tabular-nums"
                      x-text="formatPriceVND(price.buyPrice, price.currency)"></span>
                    <span class="text-xs ml-1"
                      :class="isUp(price.changeBuy) ? 'text-green-600' : isDown(price.changeBuy) ? 'text-red-500' : 'text-gray-400'"
                      x-text="isUp(price.changeBuy) ? '▲' : isDown(price.changeBuy) ? '▼' : '—'"></span>
                    <span x-show="price.changeBuy !== 0" class="text-[11px] text-gray-500 ml-0.5"
                      x-text="formatChange(price.changeBuy)"></span>
                  </td>
                  <td class="py-3.5 px-5 text-center">
                    <span class="text-pq-red font-bold text-[15px] tabular-nums"
                      x-text="price.sellPrice > 0 ? formatPriceVND(price.sellPrice, price.currency) : '—'"></span>
                    <span class="text-xs ml-1"
                      :class="isUp(price.changeSell) ? 'text-green-600' : isDown(price.changeSell) ? 'text-red-500' : 'text-gray-400'"
                      x-text="isUp(price.changeSell) ? '▲' : isDown(price.changeSell) ? '▼' : '—'"></span>
                    <span x-show="price.changeSell !== 0" class="text-[11px] text-gray-500 ml-0.5"
                      x-text="formatChange(price.changeSell)"></span>
                  </td>
                  <td class="py-3.5 px-5 text-center">
                    <button @click="openEditModal(price)"
                      class="text-gray-300 hover:text-pq-red transition-colors opacity-0 group-hover:opacity-100"
                      title="Chỉnh sửa">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                      </svg>
                    </button>
                  </td>
                </tr>
              </template>

              <!-- World gold XAU/USD row -->
              <template x-if="xauusd">
                <tr class="bg-yellow-50 border-b border-gray-100">
                  <td class="py-3.5 px-5 text-[14px] text-gray-800 font-medium" x-text="xauusd.goldName"></td>
                  <td class="py-3.5 px-5 text-center">
                    <span class="text-pq-red font-bold text-[15px] tabular-nums"
                      x-text="new Intl.NumberFormat('en-US',{minimumFractionDigits:2}).format(xauusd.buyPrice) + ' USD'"></span>
                    <span class="text-[11px] ml-1" :class="isUp(xauusd.changeBuy) ? 'text-green-600' : 'text-red-500'"
                      x-text="isUp(xauusd.changeBuy) ? '▲' : '▼'"></span>
                  </td>
                  <td class="py-3.5 px-5 text-center text-gray-400 text-sm">—</td>
                  <td class="py-3.5 px-5"></td>
                </tr>
              </template>

              <!-- Empty state -->
              <template x-if="goldPrices.length === 0">
                <tr>
                  <td colspan="4" class="py-16 text-center text-gray-400 text-sm">Chưa có dữ liệu giá trong hệ thống.
                  </td>
                </tr>
              </template>
            </tbody>
          </table>
        </div>

        <!-- Note -->
        <div class="mt-3 text-[12px] text-gray-500 flex items-center gap-1.5">
          <span class="text-gray-400">&#x2022;</span>
          Đơn giá trên đã bao gồm thuế GTGT. Liên hệ
          <a href="tel:0363778889" class="text-pq-red font-semibold hover:underline">0363.778.889</a>
          để báo giá chính xác nhất.
          <span class="ml-auto text-gray-400" x-text="'Cập nhật lần cuối: ' + (lastUpdated || '...')"></span>
        </div>
      </div>

    </div>
  </main>
</Layout>
