---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tài khoản - Vàng An Thịnh" description="Quản lý tài khoản Vàng An Thịnh - Thông tin cá nhân, đơn hàng, xác minh KYC." variant="inner">
  <main class="min-h-screen bg-light-bg" x-data="profilePage">

    <!-- Loading State -->
    <div x-show="loading" class="flex items-center justify-center py-20">
      <svg class="animate-spin w-8 h-8 text-accent" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
    </div>

    <!-- Profile Content -->
    <div x-show="!loading" class="max-w-4xl mx-auto px-4 py-12">

      <!-- Page Title -->
      <div class="mb-8">
        <h1 class="font-heading text-3xl text-primary font-bold">Tài khoản của tôi</h1>
        <div class="w-16 h-1 bg-accent mt-2"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">

        <!-- Sidebar -->
        <div class="md:col-span-1">
          <div class="bg-white rounded-xl shadow-sm p-6">
            <!-- Avatar -->
            <div class="text-center mb-6">
              <div class="w-20 h-20 bg-primary rounded-full flex items-center justify-center mx-auto mb-3">
                <span class="text-accent font-heading text-3xl font-bold"
                  x-text="user?.username?.[0]?.toUpperCase() || 'U'"></span>
              </div>
              <h2 class="font-semibold text-primary text-lg" x-text="user?.username"></h2>
              <p class="text-sm text-gray-500" x-text="user?.email"></p>
            </div>

            <!-- Nav Links -->
            <nav class="space-y-1">
              <a href="/tai-khoan"
                class="block py-2 px-3 rounded-lg bg-light-bg text-accent font-medium text-sm">Thông tin tài khoản</a>
              <a href="/don-hang"
                class="block py-2 px-3 rounded-lg hover:bg-light-bg text-primary text-sm transition-colors">Lịch sử đơn
                hàng</a>
              <a href="/yeu-thich.html"
                class="block py-2 px-3 rounded-lg hover:bg-light-bg text-primary text-sm transition-colors">Sản phẩm yêu
                thích</a>
              <button @click="logout()"
                class="w-full text-left py-2 px-3 rounded-lg hover:bg-red-50 text-error text-sm transition-colors">Đăng
                xuất</button>
            </nav>
          </div>
        </div>

        <!-- Main Content -->
        <div class="md:col-span-2 space-y-6">

          <!-- User Info Card -->
          <div class="bg-white rounded-xl shadow-sm p-6">
            <h3 class="font-heading text-lg text-primary font-semibold mb-4">Thông tin cá nhân</h3>
            <div class="space-y-4">
              <div class="flex items-center justify-between py-3 border-b border-gray-100">
                <span class="text-sm text-gray-500">Tên đăng nhập</span>
                <span class="text-sm font-medium text-primary" x-text="user?.username"></span>
              </div>
              <div class="flex items-center justify-between py-3 border-b border-gray-100">
                <span class="text-sm text-gray-500">Email</span>
                <span class="text-sm font-medium text-primary" x-text="user?.email"></span>
              </div>
              <div class="flex items-center justify-between py-3">
                <span class="text-sm text-gray-500">Trạng thái KYC</span>
                <span class="text-sm font-semibold px-3 py-1 rounded-full" :class="kycColor" x-text="kycLabel"></span>
              </div>
            </div>
          </div>

          <!-- KYC Upload Section -->
          <div class="bg-white rounded-xl shadow-sm p-6">
            <h3 class="font-heading text-lg text-primary font-semibold mb-2">Xác minh danh tính (KYC)</h3>
            <p class="text-sm text-gray-500 mb-4">Xác minh danh tính để mua bán vàng miếng và sử dụng đầy đủ tính năng.
            </p>

            <template x-if="user?.kycStatus === 'verified'">
              <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-sm text-green-700">
                Tài khoản của bạn đã được xác minh thành công.
              </div>
            </template>

            <template x-if="user?.kycStatus === 'pending'">
              <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 text-sm text-yellow-700">
                Hồ sơ KYC của bạn đang được xem xét. Vui lòng chờ trong 1-2 ngày làm việc.
              </div>
            </template>

            <template x-if="user?.kycStatus === 'rejected'">
              <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-700 mb-4">
                Hồ sơ KYC bị từ chối. Vui lòng gửi lại với thông tin chính xác.
              </div>
            </template>

            <template x-if="!user?.kycStatus || user?.kycStatus === 'rejected'">
              <div class="mt-4">
                <div x-show="kycError" class="mb-3 bg-red-50 text-error text-sm p-3 rounded-lg" x-text="kycError"></div>
                <div class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center" @dragover.prevent
                  @drop.prevent="handleFileDrop">
                  <svg class="w-12 h-12 mx-auto mb-3 text-gray-400" fill="none" stroke="currentColor"
                    viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <p class="text-sm text-gray-500 mb-3">Tải lên 2 ảnh CMND/CCCD (mặt trước và mặt sau) hoặc kéo thả vào
                    đây</p>

                  <input type="file" id="kycFiles" multiple accept="image/jpeg, image/png" class="hidden"
                    @change="handleFileSelect" />
                  <label for="kycFiles"
                    class="cursor-pointer inline-block bg-accent text-white px-6 py-2 rounded-lg text-sm font-semibold hover:bg-accent-dark transition-colors">
                    Chọn tệp tải lên
                  </label>

                  <p class="text-xs text-gray-400 mt-2">Đã chọn: <span x-text="kycFiles.length"></span>/2 ảnh</p>
                </div>

                <button x-show="kycFiles.length > 0" @click="uploadKyc" :disabled="submittingKyc"
                  class="mt-4 w-full bg-primary text-white py-3 rounded-lg text-sm font-bold hover:bg-accent transition-colors disabled:opacity-50 flex justify-center gap-2 items-center">
                  <span x-show="!submittingKyc">Gửi yêu cầu xác minh</span>
                  <span x-show="submittingKyc" class="flex gap-2 items-center">
                    <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z">
                      </path>
                    </svg>
                    Đang gửi...
                  </span>
                </button>
              </div>
            </template>
          </div>

          <!-- Quick Links -->
          <div class="bg-white rounded-xl shadow-sm p-6">
            <h3 class="font-heading text-lg text-primary font-semibold mb-4">Truy cập nhanh</h3>
            <div class="grid grid-cols-2 gap-4">
              <a href="/don-hang"
                class="flex items-center gap-3 p-4 border border-gray-100 rounded-lg hover:border-accent hover:bg-light-bg transition-colors group">
                <svg class="w-8 h-8 text-gray-400 group-hover:text-accent transition-colors" fill="none"
                  stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-primary">Đơn hàng</p>
                  <p class="text-xs text-gray-500">Xem lịch sử mua hàng</p>
                </div>
              </a>
              <a href="/yeu-thich.html"
                class="flex items-center gap-3 p-4 border border-gray-100 rounded-lg hover:border-accent hover:bg-light-bg transition-colors group">
                <svg class="w-8 h-8 text-gray-400 group-hover:text-accent transition-colors" fill="none"
                  stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-primary">Yêu thích</p>
                  <p class="text-xs text-gray-500">Sản phẩm đã lưu</p>
                </div>
              </a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>
</Layout>
