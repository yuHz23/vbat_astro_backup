---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout title="Giỏ hàng - Vàng An Thịnh" description="Giỏ hàng mua sắm tại Vàng An Thịnh." variant="inner" showTicker={false}>

  <Breadcrumb items={[
    { label: 'Trang chủ', href: '/' },
    { label: 'Giỏ hàng' }
  ]} />

  <section class="py-12">
    <div class="max-w-5xl mx-auto px-4">
      <h1 class="font-heading text-3xl text-primary mb-8">Giỏ Hàng</h1>

      <!-- Empty Cart -->
      <template x-if="$store.cart.items.length === 0">
        <div class="text-center py-20 bg-white rounded-2xl shadow-sm">
          <svg class="w-24 h-24 mx-auto mb-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          <h2 class="text-xl text-gray-500 font-medium mb-2">Giỏ hàng trống</h2>
          <p class="text-gray-400 text-sm mb-6">Bạn chưa thêm sản phẩm nào vào giỏ hàng</p>
          <a href="/san-pham.html" class="inline-block bg-accent text-white px-8 py-3 rounded-lg font-semibold hover:bg-accent-dark transition-colors">Mua sắm ngay</a>
        </div>
      </template>

      <!-- Cart Items -->
      <template x-if="$store.cart.items.length > 0">
        <div class="grid lg:grid-cols-3 gap-8">
          <div class="lg:col-span-2 space-y-4">
            <template x-for="item in $store.cart.items" :key="item.key">
              <div class="bg-white rounded-xl shadow-sm p-4 flex gap-4">
                <img :src="item.image" class="w-24 h-24 object-cover rounded-lg" :alt="item.name" />
                <div class="flex-1">
                  <h3 class="font-medium text-primary" x-text="item.name"></h3>
                  <p x-show="item.variant" class="text-sm text-gray-500 mt-1" x-text="item.variant"></p>
                  <p class="text-accent font-bold mt-2" x-text="new Intl.NumberFormat('vi-VN').format(item.price) + ' ₫'"></p>
                  <div class="flex items-center justify-between mt-3">
                    <div class="flex items-center gap-2">
                      <button @click="$store.cart.updateQuantity(item.key, item.quantity - 1)" class="w-8 h-8 border rounded-lg text-sm hover:bg-light-bg flex items-center justify-center">-</button>
                      <span class="w-10 text-center font-medium" x-text="item.quantity"></span>
                      <button @click="$store.cart.updateQuantity(item.key, item.quantity + 1)" class="w-8 h-8 border rounded-lg text-sm hover:bg-light-bg flex items-center justify-center">+</button>
                    </div>
                    <div class="flex items-center gap-4">
                      <span class="font-bold text-primary" x-text="new Intl.NumberFormat('vi-VN').format(item.price * item.quantity) + ' ₫'"></span>
                      <button @click="$store.cart.remove(item.key)" class="text-gray-400 hover:text-error transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </template>
          </div>
          <!-- Summary -->
          <div class="bg-white rounded-xl shadow-sm p-6 h-fit sticky top-24">
            <h2 class="font-heading text-xl text-primary mb-4">Tóm Tắt Đơn Hàng</h2>
            <div class="space-y-3 text-sm border-b pb-4 mb-4">
              <div class="flex justify-between"><span class="text-gray-500">Số lượng sản phẩm:</span><span class="font-medium" x-text="$store.cart.count"></span></div>
              <div class="flex justify-between"><span class="text-gray-500">Tạm tính:</span><span class="font-medium" x-text="new Intl.NumberFormat('vi-VN').format($store.cart.total) + ' ₫'"></span></div>
            </div>
            <div class="flex justify-between text-lg font-bold mb-6">
              <span class="text-primary">Tổng cộng:</span>
              <span class="text-accent" x-text="new Intl.NumberFormat('vi-VN').format($store.cart.total) + ' ₫'"></span>
            </div>
            <a href="/thanh-toan.html" class="block w-full bg-accent text-white text-center py-3 rounded-lg font-semibold hover:bg-accent-dark transition-colors">Tiến hành thanh toán</a>
            <a href="/san-pham.html" class="block text-center mt-3 text-primary hover:text-accent text-sm">← Tiếp tục mua sắm</a>
          </div>
        </div>
      </template>
    </div>
  </section>

</Layout>
