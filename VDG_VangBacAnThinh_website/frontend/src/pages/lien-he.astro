---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout title="Liên hệ - Vàng An Thịnh" description="Liên hệ Vàng An Thịnh - Mua bán vàng bạc uy tín tại Hà Nội. Hotline: 0363 778 889." variant="home">
  <main class="min-h-screen">

    <Breadcrumb items={[{label: "Trang chủ", href: "/"}, {label: "Liên hệ"}]} />

    <!-- Page Header -->
    <div class="bg-gradient-to-r from-primary to-primary-light py-12">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h1 class="font-heading text-3xl md:text-4xl text-accent mb-2">Liên Hệ Với Chúng Tôi</h1>
        <p class="text-text-light text-lg">Chúng tôi luôn sẵn sàng hỗ trợ bạn</p>
      </div>
    </div>

    <!-- Contact Content -->
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4">
        <div class="grid lg:grid-cols-2 gap-12">

          <!-- Contact Info -->
          <div class="space-y-6">
            <div class="bg-white rounded-2xl shadow-lg p-8">
              <h2 class="font-heading text-2xl text-primary mb-6">Thông Tin Liên Hệ</h2>
              <div class="space-y-6">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-primary">Địa chỉ</h3>
                    <p class="text-gray-600 text-sm mt-1">Số 141P Trương Định, Phường Tương Mai, Quận Hoàng Mai, Hà Nội</p>
                  </div>
                </div>
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-primary">Hotline</h3>
                    <a href="tel:0363778889" class="text-accent font-semibold hover:text-accent-dark text-lg">0363 778 889</a>
                  </div>
                </div>
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-primary">Email</h3>
                    <a href="mailto:ankhangthinh2025@gmail.com" class="text-accent hover:text-accent-dark">ankhangthinh2025@gmail.com</a>
                  </div>
                </div>
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-primary">Facebook</h3>
                    <a href="https://www.facebook.com/p/V%C3%A0ng-An-Th%E1%BB%8Bnh-61581487539883/" target="_blank" rel="noopener" class="text-accent hover:text-accent-dark">Vàng An Thịnh</a>
                  </div>
                </div>
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
                    <span class="text-accent font-bold text-sm">ZL</span>
                  </div>
                  <div>
                    <h3 class="font-semibold text-primary">Zalo</h3>
                    <a href="https://zalo.me/0363778889" target="_blank" rel="noopener" class="text-accent hover:text-accent-dark">0363 778 889</a>
                  </div>
                </div>
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-primary">Giờ làm việc</h3>
                    <p class="text-gray-600 text-sm mt-1">Thứ 2 - Chủ nhật: 8:00 - 20:00</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Map -->
          <div class="bg-white rounded-2xl shadow-lg overflow-hidden min-h-[500px]">
            <iframe
              src="https://maps.google.com/maps?q=20.9913284,105.8488338&z=17&output=embed"
              width="100%" height="100%" style="border:0; min-height: 500px;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>

        </div>
      </div>
    </section>

  </main>
</Layout>
