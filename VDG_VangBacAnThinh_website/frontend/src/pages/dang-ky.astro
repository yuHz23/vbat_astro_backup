---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Đăng ký - Vàng An Thịnh" description="Đăng ký tài khoản Vàng An Thịnh - Mua bán vàng bạc uy tín tại Hà Nội." variant="home">
  <main class="min-h-screen bg-light-bg">
    <div class="flex items-center justify-center py-16 px-4" x-data="registerPage">
      <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8">
        <!-- Logo -->
        <div class="text-center mb-8">
          <img src="/logo-icon.png" alt="An Thịnh" class="w-16 h-16 rounded-full object-cover mx-auto mb-4" />
          <h1 class="font-heading text-2xl text-primary font-bold">Đăng ký tài khoản</h1>
          <p class="text-gray-500 text-sm mt-1">Tạo tài khoản để mua sắm tại Vàng An Thịnh</p>
        </div>

        <!-- Error -->
        <div x-show="error" x-transition class="mb-4 bg-red-50 border border-red-200 text-error text-sm rounded-lg p-3" x-text="error"></div>

        <!-- Form -->
        <form @submit.prevent="register()" class="space-y-5">
          <div>
            <label for="fullName" class="block text-sm font-medium text-primary mb-1">Họ và tên</label>
            <input
              id="fullName"
              type="text"
              x-model="fullName"
              required
              placeholder="Nhập họ và tên"
              class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent text-sm transition-colors"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-primary mb-1">Số điện thoại</label>
            <input
              id="phone"
              type="tel"
              x-model="phone"
              required
              placeholder="Nhập số điện thoại"
              inputmode="numeric"
              class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent text-sm transition-colors"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-primary mb-1">Email</label>
            <input
              id="email"
              type="email"
              x-model="email"
              required
              placeholder="Nhập địa chỉ email"
              class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent text-sm transition-colors"
            />
          </div>
          <div>
            <label for="password" class="block text-sm font-medium text-primary mb-1">Mật khẩu</label>
            <input
              id="password"
              type="password"
              x-model="password"
              required
              placeholder="Tối thiểu 8 ký tự, chữ hoa, thường, số, đặc biệt"
              class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent text-sm transition-colors"
            />
            <!-- Password Strength Indicator -->
            <div x-show="password.length > 0" x-transition class="mt-2">
              <div class="flex gap-1 mb-1">
                <template x-for="i in 5" :key="i">
                  <div class="h-1 flex-1 rounded-full transition-colors" :class="i <= passwordStrength.level ? passwordStrength.color : 'bg-gray-200'"></div>
                </template>
              </div>
              <p class="text-xs" :class="passwordStrength.color.replace('bg-', 'text-')" x-text="'Độ mạnh: ' + passwordStrength.label"></p>
              <ul class="text-xs text-gray-400 mt-1 space-y-0.5">
                <li :class="password.length >= 8 ? 'text-green-500' : ''">&#x2022; Tối thiểu 8 ký tự</li>
                <li :class="/[A-Z]/.test(password) ? 'text-green-500' : ''">&#x2022; Chứa chữ cái viết hoa (A-Z)</li>
                <li :class="/[a-z]/.test(password) ? 'text-green-500' : ''">&#x2022; Chứa chữ cái viết thường (a-z)</li>
                <li :class="/[0-9]/.test(password) ? 'text-green-500' : ''">&#x2022; Chứa chữ số (0-9)</li>
                <li :class="/[!@#$%^&*()_+\-=\[\]{};':&quot;\\|,.<>\/?]/.test(password) ? 'text-green-500' : ''">&#x2022; Chứa ký tự đặc biệt (!@#$%...)</li>
              </ul>
            </div>
          </div>
          <div>
            <label for="confirmPassword" class="block text-sm font-medium text-primary mb-1">Xác nhận mật khẩu</label>
            <input
              id="confirmPassword"
              type="password"
              x-model="confirmPassword"
              required
              placeholder="Nhập lại mật khẩu"
              class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent text-sm transition-colors"
            />
          </div>
          <button
            type="submit"
            :disabled="loading"
            class="w-full bg-accent text-white py-3 rounded-lg font-semibold hover:bg-accent-dark transition-colors disabled:opacity-50 text-sm"
          >
            <span x-show="!loading">Đăng ký</span>
            <span x-show="loading" class="flex items-center justify-center gap-2">
              <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
              Đang xử lý...
            </span>
          </button>
        </form>

        <!-- Login Link -->
        <p class="text-center text-sm text-gray-500 mt-6">
          Đã có tài khoản?
          <a href="/dang-nhap" class="text-accent font-semibold hover:text-accent-dark transition-colors">Đăng nhập</a>
        </p>
      </div>
    </div>
  </main>
</Layout>
