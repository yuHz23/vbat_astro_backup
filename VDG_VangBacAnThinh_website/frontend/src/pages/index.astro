---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Vàng An Thịnh - Mua Bán Vàng Bạc Uy Tín" description="Vàng An Thịnh - Mua bán vàng bạc uy tín tại Hà Nội. Giá vàng cập nhật liên tục, trang sức chất lượng cao." variant="home" showTicker={true}>

  <main>

    <!-- Hero Banner with Video Background -->
    <section class="relative overflow-hidden bg-[#0B1320]" style="min-height: 560px;">
      <!-- Video Background -->
      <div class="absolute inset-0">
        <video autoplay muted loop playsinline class="absolute w-full h-full object-cover opacity-60">
          <source src="/hero-gold-bg.mp4" type="video/mp4">
        </video>
        <!-- Dark overlay for readability -->
        <div class="absolute inset-0 bg-gradient-to-r from-[#0B1320]/90 via-[#0B1320]/60 to-[#0B1320]/40"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#0B1320]/80 via-transparent to-[#0B1320]/30"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 max-w-7xl mx-auto px-4 py-20 md:py-28 flex flex-col md:flex-row items-center gap-10 md:gap-16">
        <!-- Left: Text -->
        <div class="md:w-3/5 text-center md:text-left">
          <div class="inline-flex items-center gap-2 bg-accent/15 text-accent text-xs font-sans font-bold uppercase tracking-[0.25em] px-5 py-2 rounded-full mb-8 border border-accent/25 backdrop-blur-sm">
            <span class="w-1.5 h-1.5 bg-accent rounded-full animate-pulse"></span>
            Uy tín từ năm 2010
          </div>
          <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl text-white font-bold leading-[1.15] mb-5">
            Tích Lũy <span class="text-accent italic">Giá Trị</span><br>
            <span class="text-white/80 font-normal">Vững Bền Tương Lai</span>
          </h1>
          <p class="font-sans text-white/55 text-base md:text-lg mb-10 max-w-xl leading-relaxed">
            Vàng An Thịnh — chuyên cung cấp vàng miếng, nhẫn trơn 999.9, bạc thỏi nguyên chất và bạc mỹ nghệ cao cấp tại Hà Nội.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
            <a href="/san-pham.html"
              class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent-dark text-white font-sans font-semibold py-3.5 px-10 rounded-full transition-all text-sm uppercase tracking-wider shadow-lg shadow-accent/25 hover:shadow-accent/40">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              Xem Vàng
            </a>
            <a href="/san-pham-bac.html"
              class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white border border-white/20 font-sans font-semibold py-3.5 px-10 rounded-full transition-all text-sm uppercase tracking-wider backdrop-blur-sm">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              Xem Bạc
            </a>
          </div>
        </div>

        <!-- Right: Stats / Highlights -->
        <div class="md:w-2/5 hidden md:flex flex-col gap-5">
          <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-accent/15 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              </div>
              <div>
                <p class="font-heading text-2xl text-white font-bold">999.9</p>
                <p class="font-sans text-white/50 text-sm">Vàng nguyên chất</p>
              </div>
            </div>
          </div>
          <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-accent/15 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              </div>
              <div>
                <p class="font-heading text-2xl text-white font-bold">100%</p>
                <p class="font-sans text-white/50 text-sm">Cam kết chính hãng</p>
              </div>
            </div>
          </div>
          <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-accent/15 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <p class="font-heading text-2xl text-white font-bold">24/7</p>
                <p class="font-sans text-white/50 text-sm">Cập nhật giá liên tục</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Bang Gia Navigation Cards -->
    <section class="py-12 md:py-16 bg-white relative">
      <div class="max-w-5xl mx-auto px-4">
        <!-- Fake Ticker Bar -->
        <div class="hidden md:flex mb-10 bg-gray-50 border border-gray-100 rounded-lg py-3 px-4 items-center shadow-sm">
          <div class="flex items-center gap-2 text-sm font-semibold mr-8 border-r border-gray-200 pr-8">
            <span class="text-primary font-bold">VNĐ</span>
            <span class="text-green-600 bg-green-50 px-1.5 py-0.5 rounded flex items-center gap-0.5 text-xs">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
              </svg>
              0.27%
            </span>
          </div>
          <div class="flex-1 overflow-hidden relative" x-data="{
            priceTopText: 'Đang tải dữ liệu thị trường...',
            async init() {
              try {
                const res = await (await fetch('/api/gold-prices?filters[isActive][$eq]=true&sort[0]=sortOrder:asc&pagination[pageSize]=2')).json();
                if(res.data && res.data.length > 0) {
                  const p1 = res.data[0];
                  this.priceTopText = `${p1.goldName} - MV: ${new Intl.NumberFormat('vi-VN').format(p1.buyPrice)} | BR: ${new Intl.NumberFormat('vi-VN').format(p1.sellPrice)}`;
                }
              } catch(e) {}
            }
          }">
            <marquee class="text-sm font-medium text-gray-800 block w-full">
              <span class="font-bold text-primary mr-2">Cập nhật:</span>
              <span x-text="priceTopText"></span>
            </marquee>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <!-- Bang Gia Vang Card -->
          <div
            class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 md:p-10 flex flex-col justify-between items-center text-center hover:shadow-xl transition-all group">
            <div class="w-full">
              <div class="flex items-center justify-center gap-3 mb-6">
                <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary uppercase tracking-wide">Bảng Giá
                  Vàng</h2>
                <div
                  class="w-10 h-10 rounded-full border border-accent/30 bg-accent/10 flex items-center justify-center group-hover:bg-accent group-hover:text-white text-accent transition-colors">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                </div>
              </div>
              <p class="text-gray-600 mb-2 font-medium">Cập nhật liên tục giá Vàng miếng, Vàng 999,9</p>
              <p class="text-gray-500 text-sm mb-10">Vàng trang sức - tại An Thịnh theo thời gian thực</p>
            </div>
            <a href="/bang-gia-vang.html"
              class="bg-gradient-to-r from-accent to-accent-light text-white font-semibold py-3.5 px-12 rounded-full shadow-md group-hover:shadow-lg group-hover:from-accent-dark group-hover:to-accent transition-all text-sm uppercase tracking-wider">
              Xem chi tiết
            </a>
          </div>

          <!-- Bang Gia Bac Card -->
          <div
            class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 md:p-10 flex flex-col justify-between items-center text-center hover:shadow-xl transition-all group">
            <div class="w-full">
              <div class="flex items-center justify-center gap-3 mb-6">
                <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary uppercase tracking-wide">Bảng Giá
                  Bạc</h2>
                <div
                  class="w-10 h-10 rounded-full border border-gray-300 bg-gray-50 flex items-center justify-center group-hover:bg-gray-400 group-hover:text-white text-gray-400 transition-colors">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                </div>
              </div>
              <p class="text-gray-600 mb-2 font-medium">Cập nhật liên tục Giá bạc miếng, Bạc thỏi</p>
              <p class="text-gray-500 text-sm mb-10">Bạc mỹ nghệ - tại An Thịnh theo thời gian thực</p>
            </div>
            <a href="/bang-gia-bac.html"
              class="bg-gradient-to-r from-gray-400 to-gray-300 text-white font-semibold py-3.5 px-12 rounded-full shadow-md group-hover:shadow-lg group-hover:from-gray-500 group-hover:to-gray-400 transition-all text-sm uppercase tracking-wider">
              Xem chi tiết
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- VÀNG - Red Theme -->
    <section class="py-14 md:py-20 bg-gradient-to-br from-[#B31B24] to-[#8B0000] relative overflow-hidden" x-data="{
      products: [],
      async init() {
        try {
          const res = await (await fetch('/api/products?filters[category][name][$eq]=VÀNG&populate=images&pagination[pageSize]=4&sort[0]=price:asc')).json();
          this.products = res.data || [];
        } catch(e) { console.error(e); }
      }
    }">
      <div class="max-w-7xl mx-auto px-4 relative z-10">
        <div class="flex flex-col xl:flex-row gap-10 items-center">
          <!-- Text -->
          <div class="xl:w-1/3 text-white text-center xl:text-left">
            <div class="inline-block bg-white/10 text-white/90 text-xs font-bold uppercase tracking-[0.3em] px-4 py-1.5 rounded-full mb-4 border border-white/20">Vàng 999.9</div>
            <h2 class="font-heading text-4xl md:text-5xl mb-4 font-bold leading-tight italic">Vàng Tích Trữ</h2>
            <div class="w-16 h-[2px] bg-accent mb-6 mx-auto xl:mx-0"></div>
            <p class="text-white/80 text-base mb-8 leading-relaxed">Nhẫn tròn trơn, Vàng miếng, Thần tài 999.9 - Tích lũy giá trị, vững bền tương lai.</p>
            <a href="/san-pham.html" class="inline-block border-2 border-white text-white px-8 py-3 rounded-full hover:bg-white hover:text-[#B31B24] transition-colors font-medium uppercase text-sm tracking-wider">
              Xem tất cả Vàng
            </a>
          </div>
          <!-- Products -->
          <div class="xl:w-2/3 w-full">
            <div x-show="products.length === 0" class="text-center py-10 text-white/50">Đang tải sản phẩm...</div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <template x-for="product in products" :key="product.id">
                <div x-data="productCard" class="bg-white rounded-xl flex flex-col group relative hover:shadow-xl transition-all h-full">
                  <span x-show="product.status === 'available'" class="absolute top-2 left-2 bg-red-50 text-[#B31B24] text-[10px] px-2 py-1 rounded-full font-semibold z-10">Còn hàng</span>
                  <a :href="'/san-pham-chi-tiet.html?slug=' + product.slug" class="block p-4 flex-1">
                    <div class="relative overflow-hidden aspect-square mb-3 rounded-lg bg-red-50/30">
                      <img :src="getStrapiMedia(product.images?.[0]?.url)" :alt="product.name" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-500" />
                    </div>
                    <h3 class="text-xs font-semibold text-primary line-clamp-2 leading-snug group-hover:text-[#B31B24] transition-colors" x-text="product.name"></h3>
                  </a>
                  <div class="px-4 pb-4 mt-auto border-t border-red-50 pt-2">
                    <div class="text-sm font-bold text-[#B31B24]" x-text="formatPriceVND(product.price)"></div>
                    <div class="text-[10px] text-gray-400 mt-0.5" x-text="'MV: ' + formatPriceVND(product.compareAtPrice)"></div>
                  </div>
                </div>
              </template>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- BẠC TÍCH TRỮ - Navy Theme -->
    <section class="py-14 md:py-20 bg-gradient-to-br from-[#1C2C47] to-[#111A2C] relative overflow-hidden" x-data="{
      products: [],
      async init() {
        try {
          const res = await (await fetch('/api/products?filters[category][name][$eq]=BẠC TÍCH TRỮ&populate=images&pagination[pageSize]=4&sort[0]=price:asc')).json();
          this.products = res.data || [];
        } catch(e) { console.error(e); }
      }
    }">
      <div class="max-w-7xl mx-auto px-4 relative z-10">
        <div class="flex flex-col xl:flex-row-reverse gap-10 items-center">
          <!-- Text -->
          <div class="xl:w-1/3 text-white text-center xl:text-right">
            <div class="inline-block bg-white/10 text-white/90 text-xs font-bold uppercase tracking-[0.3em] px-4 py-1.5 rounded-full mb-4 border border-white/20">Bạc 999</div>
            <h2 class="font-heading text-4xl md:text-5xl mb-4 font-bold leading-tight italic">Bạc Tích Trữ</h2>
            <div class="w-16 h-[2px] bg-accent mb-6 mx-auto xl:mr-0 xl:ml-auto"></div>
            <p class="text-white/80 text-base mb-8 leading-relaxed">Bạc thỏi, bạc miếng nguyên chất 999 - Đầu tư an toàn, giá trị bền vững.</p>
            <a href="/san-pham-bac.html" class="inline-block border-2 border-white text-white px-8 py-3 rounded-full hover:bg-white hover:text-primary transition-colors font-medium uppercase text-sm tracking-wider">
              Xem tất cả Bạc tích trữ
            </a>
          </div>
          <!-- Products -->
          <div class="xl:w-2/3 w-full">
            <div x-show="products.length === 0" class="text-center py-10 text-white/50">Đang tải sản phẩm...</div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <template x-for="product in products" :key="product.id">
                <div x-data="productCard" class="bg-white rounded-xl flex flex-col group relative hover:shadow-xl transition-all h-full">
                  <span x-show="product.status === 'available'" class="absolute top-2 left-2 bg-blue-50 text-primary text-[10px] px-2 py-1 rounded-full font-semibold z-10">Còn hàng</span>
                  <span x-show="product.status === 'out_of_stock'" class="absolute top-2 left-2 bg-gray-100 text-gray-500 text-[10px] px-2 py-1 rounded-full font-semibold z-10">Hết hàng</span>
                  <a :href="'/san-pham-chi-tiet.html?slug=' + product.slug" class="block p-4 flex-1">
                    <div class="relative overflow-hidden aspect-square mb-3 rounded-lg bg-blue-50/30">
                      <img :src="getStrapiMedia(product.images?.[0]?.url)" :alt="product.name" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-500" />
                    </div>
                    <h3 class="text-xs font-semibold text-primary line-clamp-2 leading-snug group-hover:text-accent transition-colors" x-text="product.name"></h3>
                  </a>
                  <div class="px-4 pb-4 mt-auto border-t border-blue-50 pt-2">
                    <div class="text-sm font-bold text-primary" x-text="formatPriceVND(product.price)"></div>
                    <div class="text-[10px] text-gray-400 mt-0.5" x-text="'MV: ' + formatPriceVND(product.compareAtPrice)"></div>
                  </div>
                </div>
              </template>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- BẠC MỸ NGHỆ - White Theme -->
    <section class="py-14 md:py-20 bg-white" x-data="{
      products: [],
      async init() {
        try {
          const res = await (await fetch('/api/products?filters[category][name][$eq]=BẠC MỸ NGHỆ&populate=images&pagination[pageSize]=8&sort[0]=price:desc')).json();
          this.products = res.data || [];
        } catch(e) { console.error(e); }
      }
    }">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-primary text-sm uppercase tracking-[0.3em] mb-2">Sưu tầm & Quà tặng</p>
          <h2 class="font-heading text-3xl md:text-4xl text-primary italic">Bạc Mỹ Nghệ</h2>
          <div class="w-16 h-[2px] bg-accent mx-auto mt-4"></div>
        </div>

        <div x-show="products.length === 0" class="text-center py-10 text-gray-400">Đang tải sản phẩm...</div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
          <template x-for="product in products" :key="product.id">
            <div x-data="productCard" class="bg-white rounded-xl border border-gray-100 flex flex-col group relative hover:shadow-lg hover:border-gray-200 transition-all h-full">
              <span x-show="product.status === 'available'" class="absolute top-3 left-3 bg-blue-50 text-primary text-[10px] px-2.5 py-1 rounded-full font-semibold z-10 uppercase tracking-wider">Còn hàng</span>
              <span x-show="product.status === 'out_of_stock'" class="absolute top-3 left-3 bg-gray-100 text-gray-500 text-[10px] px-2.5 py-1 rounded-full font-semibold z-10 uppercase tracking-wider">Hết hàng</span>

              <a :href="'/san-pham-chi-tiet.html?slug=' + product.slug" class="block p-5 flex-1">
                <div class="relative overflow-hidden aspect-square mb-4 rounded-lg bg-blue-50/30">
                  <img :src="getStrapiMedia(product.images?.[0]?.url)" :alt="product.name" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-500" />
                </div>
                <h3 class="text-xs md:text-sm font-semibold text-primary line-clamp-2 leading-snug group-hover:text-accent transition-colors" x-text="product.name"></h3>
                <p class="text-[10px] text-gray-400 mt-1" x-text="product.karatType"></p>
              </a>

              <div class="px-5 pb-5 mt-auto border-t border-gray-50 pt-3">
                <div class="flex justify-between items-end">
                  <div>
                    <div class="text-sm font-bold text-primary leading-none" x-text="formatPriceVND(product.price)"></div>
                    <div class="text-[10px] text-gray-400 mt-0.5" x-text="'MV: ' + formatPriceVND(product.compareAtPrice)"></div>
                  </div>
                  <button @click="addToCart(product)" x-show="product.status === 'available'" class="p-2.5 text-gray-300 hover:text-white bg-white hover:bg-primary border border-gray-100 hover:border-primary rounded-full transition-all" title="Thêm vào giỏ">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </template>
        </div>

        <div class="text-center mt-10">
          <a href="/san-pham-bac.html" class="inline-block border-2 border-primary text-primary px-10 py-3 rounded-full font-medium hover:bg-primary hover:text-white transition-colors text-sm uppercase tracking-wider">
            Xem tất cả Bạc mỹ nghệ
          </a>
        </div>
      </div>
    </section>

    <!-- Category Showcase -->
    <section class="py-16" x-data="{
      categories: [],
      async init() {
        try {
          const res = await (await fetch('/api/product-categories?populate=image&sort[0]=sortOrder:asc&pagination[pageSize]=6')).json();
          this.categories = res.data || [];
        } catch(e) { console.error(e); }
      }
    }">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-10">
          <h2 class="font-heading text-3xl md:text-4xl text-primary mb-2">Danh Mục Sản Phẩm</h2>
          <div class="w-20 h-1 bg-accent mx-auto"></div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
          <template x-for="cat in categories" :key="cat.id">
            <a :href="'/san-pham.html?category=' + cat.slug"
              class="group relative rounded-xl overflow-hidden aspect-[4/3]">
              <img
                :src="window.__mediaUrl(cat.image?.url)"
                :alt="cat.name"
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent flex items-end p-6">
                <h3 class="font-heading text-xl text-text-light group-hover:text-accent transition-colors"
                  x-text="cat.name"></h3>
              </div>
            </a>
          </template>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="py-16 bg-primary" x-data="{
      testimonials: [],
      async init() {
        try {
          const res = await (await fetch('/api/testimonials?pagination[pageSize]=6')).json();
          this.testimonials = res.data || [];
        } catch(e) { console.error(e); }
      }
    }">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-10">
          <h2 class="font-heading text-3xl md:text-4xl text-accent mb-2">Khách Hàng Nói Gì</h2>
          <div class="w-20 h-1 bg-accent mx-auto"></div>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          <template x-for="t in testimonials" :key="t.id">
            <div class="bg-primary-light rounded-xl p-6">
              <div class="flex items-center gap-1 mb-3">
                <template x-for="i in 5" :key="i">
                  <svg :class="i <= t.rating ? 'text-accent' : 'text-gray-600'" class="w-4 h-4" fill="currentColor"
                    viewBox="0 0 20 20">
                    <path
                      d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                </template>
              </div>
              <p class="text-text-light text-sm italic mb-4" x-text="`&quot;${t.content}&quot;`"></p>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-accent rounded-full flex items-center justify-center text-white font-bold"
                  x-text="t.customerName?.[0]?.toUpperCase()"></div>
                <span class="text-accent font-medium text-sm" x-text="t.customerName"></span>
              </div>
            </div>
          </template>
        </div>
      </div>
    </section>

    <!-- Latest Articles -->
    <section class="py-16" x-data="{
      articles: [],
      async init() {
        try {
          const res = await (await fetch('/api/articles?populate=coverImage&sort[0]=publishedDate:desc&pagination[pageSize]=3')).json();
          this.articles = res.data || [];
        } catch(e) { console.error(e); }
      }
    }">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-10">
          <h2 class="font-heading text-3xl md:text-4xl text-primary mb-2">Tin Tức & Kiến Thức</h2>
          <div class="w-20 h-1 bg-accent mx-auto"></div>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          <template x-for="a in articles" :key="a.id">
            <a :href="'/bai-viet.html?slug=' + a.slug"
              class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow group">
              <div class="aspect-video overflow-hidden">
                <img
                  :src="window.__mediaUrl(a.coverImage?.url)"
                  :alt="a.title"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="p-5">
                <div class="text-xs text-gray-400 mb-2"
                  x-text="a.publishedDate ? new Date(a.publishedDate).toLocaleDateString('vi-VN') : ''"></div>
                <h3
                  class="font-heading text-lg text-primary group-hover:text-accent transition-colors line-clamp-2 mb-2"
                  x-text="a.title"></h3>
                <p class="text-sm text-gray-600 line-clamp-3" x-text="a.excerpt"></p>
              </div>
            </a>
          </template>
        </div>
        <div class="text-center mt-10">
          <a href="/tin-tuc.html"
            class="inline-block border-2 border-primary text-primary px-8 py-3 rounded-lg font-semibold hover:bg-primary hover:text-white transition-colors">Xem
            tất cả tin tức</a>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <section class="py-16 bg-gradient-to-r from-primary to-primary-light" x-data="newsletter">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="font-heading text-3xl text-accent mb-3">Đăng Ký Nhận Tin</h2>
        <p class="text-text-light mb-6">Nhận thông tin giá vàng và ưu đãi mới nhất từ Vàng An Thịnh</p>
        <form @submit.prevent="subscribe()" class="flex gap-3 max-w-md mx-auto">
          <input type="email" x-model="email" placeholder="Email của bạn" required
            class="flex-1 px-4 py-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent text-sm" />
          <button type="submit" :disabled="submitting"
            class="bg-accent text-white px-6 py-3 rounded-lg font-semibold hover:bg-accent-dark transition-colors disabled:opacity-50 text-sm">
            <span x-show="!submitting">Đăng ký</span>
            <span x-show="submitting">...</span>
          </button>
        </form>
        <p x-show="status === 'success'" class="mt-3 text-green-400 text-sm" x-text="message"></p>
        <p x-show="status === 'error'" class="mt-3 text-red-400 text-sm" x-text="message"></p>
      </div>
    </section>

  </main>

</Layout>
