---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Vàng An Thịnh - Mua Bán Vàng Bạc Uy Tín | Hanoi" description="Vàng An Thịnh - Mua bán vàng bạc uy tín tại Hà Nội. Địa chỉ: 141P Trương Định, Tương Mai, Hoàng Mai, Hà Nội. SĐT: 0363778889. Giá vàng cập nhật liên tục." variant="home" showTicker={true}>

  <main>

    <!-- Hero Banner with Video Background -->
    <section class="relative overflow-hidden bg-[#0B1320]" style="min-height: 600px;">
      <!-- Video Background -->
      <div class="absolute inset-0">
        <video autoplay muted loop playsinline class="absolute w-full h-full object-cover opacity-50">
          <source src="/hero-video.mp4" type="video/mp4">
        </video>
        <div class="absolute inset-0 bg-gradient-to-b from-[#0B1320]/70 via-[#0B1320]/40 to-[#0B1320]/80"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 max-w-4xl mx-auto px-4 py-24 md:py-32 flex flex-col items-center text-center">
        <h1 class="font-heading text-3xl md:text-5xl lg:text-6xl text-white font-bold leading-[1.15] mb-5">
          Tích Lũy Giá Trị<br>
          Vững Bền Tương Lai
        </h1>
        <p class="font-sans text-white/60 text-base md:text-lg mb-10 max-w-2xl leading-relaxed">
          Vàng An Thịnh — chuyên cung cấp vàng miếng, nhẫn trơn 999.9, bạc thỏi nguyên chất và bạc mỹ nghệ cao cấp tại Hà Nội.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/san-pham.html"
            class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent-dark text-white font-sans font-semibold py-3.5 px-10 rounded-full transition-all text-sm uppercase tracking-wider shadow-lg shadow-accent/25 hover:shadow-accent/40">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            Xem Vàng
          </a>
          <a href="/san-pham-bac.html"
            class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white border border-white/20 font-sans font-semibold py-3.5 px-10 rounded-full transition-all text-sm uppercase tracking-wider backdrop-blur-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            Xem Bạc
          </a>
        </div>
      </div>
    </section>

    <!-- Bang Gia Cards -->
    <section class="py-12 md:py-16 bg-[#F5F5F5]" x-data="{
      goldBuy: '---', goldSell: '---', silverBuy: '---', silverSell: '---',
      async init() {
        try {
          const base = window.__strapiBase || '';
          const res = await (await fetch(base + '/api/gold-prices?filters[isActive][$eq]=true&sort[0]=sortOrder:asc&pagination[pageSize]=20')).json();
          if (res.data) {
            const sjc = res.data.find(d => d.goldType === 'SJL1L10') || res.data[0];
            if (sjc) {
              this.goldBuy = new Intl.NumberFormat('en-US').format(sjc.buyPrice);
              this.goldSell = new Intl.NumberFormat('en-US').format(sjc.sellPrice);
            }
          }
        } catch(e) {}
      }
    }">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-center font-heading text-xl md:text-2xl text-primary uppercase tracking-[0.2em] mb-2">Chọn loại giá để xem chi tiết</h2>
        <div class="w-16 h-1 bg-accent mx-auto mb-10"></div>

        <div class="grid md:grid-cols-2 gap-6 md:gap-8">
          <!-- Bang Gia Vang -->
          <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
            <div class="bg-gradient-to-r from-[#1B2B4A] to-[#2A4066] p-6 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-accent/20 rounded-xl flex items-center justify-center">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <h3 class="text-white font-heading text-xl font-bold tracking-wide">BẢNG GIÁ VÀNG</h3>
                  <div class="flex gap-1 mt-1">
                    <span class="w-2 h-2 rounded-full bg-accent"></span>
                    <span class="w-2 h-2 rounded-full bg-accent/60"></span>
                    <span class="w-2 h-2 rounded-full bg-accent/40"></span>
                    <span class="w-2 h-2 rounded-full bg-accent/20"></span>
                  </div>
                </div>
              </div>
              <span class="flex items-center gap-1.5 bg-white/10 text-green-300 text-xs font-bold px-3 py-1.5 rounded-full border border-white/20">
                <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span> LIVE
              </span>
            </div>
            <div class="p-6">
              <p class="text-gray-600 text-sm mb-1">Cập nhật liên tục Giá Vàng miếng, Vàng 999,9</p>
              <p class="text-gray-500 text-sm mb-5">Vàng trang sức – tại <strong class="text-primary">Vàng An Thịnh</strong> theo thời gian thực.</p>
              <div class="border border-gray-100 rounded-xl p-4 mb-5">
                <div class="flex justify-between items-center mb-2">
                  <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">Vàng SJC (Hôm nay)</span>
                  <span class="text-xs text-gray-400">Vnđ / lượng</span>
                </div>
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <p class="text-xs text-gray-400 mb-1">Mua vào</p>
                    <p class="text-lg font-bold text-red-600" x-text="goldBuy"></p>
                  </div>
                  <div>
                    <p class="text-xs text-gray-400 mb-1">Bán ra</p>
                    <p class="text-lg font-bold text-green-600" x-text="goldSell"></p>
                  </div>
                </div>
              </div>
              <a href="/gia-vang.html" class="flex items-center justify-center gap-2 w-full bg-accent hover:bg-accent-dark text-white font-semibold py-3.5 rounded-xl transition-colors text-sm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                Xem chi tiết Bảng Giá Vàng
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Bang Gia Bac -->
          <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
            <div class="bg-gradient-to-r from-[#374151] to-[#4B5563] p-6 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center">
                  <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <h3 class="text-white font-heading text-xl font-bold tracking-wide">BẢNG GIÁ BẠC</h3>
                  <div class="flex gap-1 mt-1">
                    <span class="w-2 h-2 rounded-full bg-gray-400"></span>
                    <span class="w-2 h-2 rounded-full bg-gray-400/60"></span>
                    <span class="w-2 h-2 rounded-full bg-gray-400/40"></span>
                    <span class="w-2 h-2 rounded-full bg-gray-400/20"></span>
                  </div>
                </div>
              </div>
              <span class="flex items-center gap-1.5 bg-white/10 text-green-300 text-xs font-bold px-3 py-1.5 rounded-full border border-white/20">
                <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span> LIVE
              </span>
            </div>
            <div class="p-6">
              <p class="text-gray-600 text-sm mb-1">Cập nhật liên tục Giá bạc miếng, Bạc thỏi</p>
              <p class="text-gray-500 text-sm mb-5">Bạc mỹ nghệ – tại <strong class="text-primary">Vàng An Thịnh</strong> theo thời gian thực.</p>
              <div class="border border-gray-100 rounded-xl p-4 mb-5">
                <div class="flex justify-between items-center mb-2">
                  <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">Bạc mỹ nghệ (Hôm nay)</span>
                  <span class="text-xs text-gray-400">Vnđ / chỉ</span>
                </div>
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <p class="text-xs text-gray-400 mb-1">Mua vào</p>
                    <p class="text-lg font-bold text-blue-600" x-text="silverBuy"></p>
                  </div>
                  <div>
                    <p class="text-xs text-gray-400 mb-1">Bán ra</p>
                    <p class="text-lg font-bold text-green-600" x-text="silverSell"></p>
                  </div>
                </div>
              </div>
              <a href="/gia-bac.html" class="flex items-center justify-center gap-2 w-full bg-gray-500 hover:bg-gray-600 text-white font-semibold py-3.5 rounded-xl transition-colors text-sm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                Xem chi tiết Bảng Giá Bạc
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- VÀNG - Red Theme -->
    <section class="py-14 md:py-20 bg-gradient-to-br from-[#B31B24] to-[#8B0000] relative overflow-hidden" x-data="{
      products: [],
      async init() {
        try {
          const base = window.__strapiBase || '';
          const res = await (await fetch(base + '/api/products?filters[category][name][$eq]=VÀNG&populate=*&pagination[pageSize]=4&sort[0]=price:asc')).json();
          this.products = res.data || [];
        } catch(e) { console.error(e); }
      }
    }">
      <div class="max-w-7xl mx-auto px-4 relative z-10">
        <div class="flex flex-col xl:flex-row gap-10 items-center">
          <!-- Text -->
          <div class="xl:w-1/3 text-white text-center xl:text-left">
            <div class="inline-block bg-white/10 text-white/90 text-xs font-bold uppercase tracking-[0.3em] px-4 py-1.5 rounded-full mb-4 border border-white/20">Vàng 999.9</div>
            <h2 class="font-heading text-4xl md:text-5xl mb-4 font-bold leading-tight italic">Vàng Tích Trữ</h2>
            <div class="w-16 h-[2px] bg-accent mb-6 mx-auto xl:mx-0"></div>
            <p class="text-white/80 text-base mb-8 leading-relaxed">Nhẫn tròn trơn, Vàng miếng, Thần tài 999.9 - Tích lũy giá trị, vững bền tương lai.</p>
            <a href="/san-pham.html" class="inline-block border-2 border-white text-white px-8 py-3 rounded-full hover:bg-white hover:text-[#B31B24] transition-colors font-medium uppercase text-sm tracking-wider">
              Xem tất cả Vàng
            </a>
          </div>
          <!-- Products -->
          <div class="xl:w-2/3 w-full">
            <div x-show="products.length === 0" class="text-center py-10 text-white/50">Đang tải sản phẩm...</div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <template x-for="product in products" :key="product.id">
                <div x-data="productCard" class="bg-white rounded-xl flex flex-col group relative hover:shadow-xl transition-all h-full">
                  <div class="absolute top-2 left-2 z-10">
                    <span class="text-[10px] px-2 py-1 rounded-sm font-semibold tracking-wide"
                      :class="{
                        'bg-[#E5F7ED] text-[#00A76F]': product.status === 'available' || product.status === 'coming_soon',
                        'bg-red-50 text-red-500': product.status === 'out_of_stock' || product.status === 'discontinued',
                      }"
                      x-text="product.status === 'available' ? 'Còn hàng' : product.status === 'coming_soon' ? 'Đặt hàng' : product.status === 'out_of_stock' ? 'Hết hàng' : product.status === 'discontinued' ? 'Dừng bán' : ''"></span>
                  </div>
                  <a :href="'/san-pham-chi-tiet.html?slug=' + product.slug" class="block p-4 flex-1">
                    <div class="relative overflow-hidden aspect-square mb-3 rounded-lg bg-red-50/30">
                      <img :src="getStrapiMedia(product.images?.[0]?.url)" :alt="product.name" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-500" />
                    </div>
                    <h3 class="text-xs font-semibold text-primary line-clamp-2 leading-snug group-hover:text-[#B31B24] transition-colors" x-text="product.name"></h3>
                  </a>
                  <div class="px-4 pb-4 mt-auto border-t border-red-50 pt-2">
                    <div class="text-sm font-bold text-[#B31B24]" x-text="formatPriceVND(product.price)"></div>
                    <div class="text-[10px] text-gray-400 mt-0.5" x-text="'MV: ' + formatPriceVND(product.compareAtPrice)"></div>
                  </div>
                </div>
              </template>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- BẠC TÍCH TRỮ - Navy Theme -->
    <section class="py-14 md:py-20 bg-gradient-to-br from-[#1C2C47] to-[#111A2C] relative overflow-hidden" x-data="{
      products: [],
      async init() {
        try {
          const base = window.__strapiBase || '';
          const res = await (await fetch(base + '/api/products?filters[category][name][$eq]=BẠC TÍCH TRỮ&populate=*&pagination[pageSize]=4&sort[0]=price:asc')).json();
          this.products = res.data || [];
        } catch(e) { console.error(e); }
      }
    }">
      <div class="max-w-7xl mx-auto px-4 relative z-10">
        <div class="flex flex-col xl:flex-row-reverse gap-10 items-center">
          <!-- Text -->
          <div class="xl:w-1/3 text-white text-center xl:text-right">
            <div class="inline-block bg-white/10 text-white/90 text-xs font-bold uppercase tracking-[0.3em] px-4 py-1.5 rounded-full mb-4 border border-white/20">Bạc 999</div>
            <h2 class="font-heading text-4xl md:text-5xl mb-4 font-bold leading-tight italic">Bạc Tích Trữ</h2>
            <div class="w-16 h-[2px] bg-accent mb-6 mx-auto xl:mr-0 xl:ml-auto"></div>
            <p class="text-white/80 text-base mb-8 leading-relaxed">Bạc thỏi, bạc miếng nguyên chất 999 - Đầu tư an toàn, giá trị bền vững.</p>
            <a href="/san-pham-bac.html" class="inline-block border-2 border-white text-white px-8 py-3 rounded-full hover:bg-white hover:text-primary transition-colors font-medium uppercase text-sm tracking-wider">
              Xem tất cả Bạc tích trữ
            </a>
          </div>
          <!-- Products -->
          <div class="xl:w-2/3 w-full">
            <div x-show="products.length === 0" class="text-center py-10 text-white/50">Đang tải sản phẩm...</div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <template x-for="product in products" :key="product.id">
                <div x-data="productCard" class="bg-white rounded-xl flex flex-col group relative hover:shadow-xl transition-all h-full">
                  <div class="absolute top-2 left-2 z-10">
                    <span class="text-[10px] px-2 py-1 rounded-sm font-semibold tracking-wide"
                      :class="{
                        'bg-[#E5F7ED] text-[#00A76F]': product.status === 'available' || product.status === 'coming_soon',
                        'bg-red-50 text-red-500': product.status === 'out_of_stock' || product.status === 'discontinued',
                      }"
                      x-text="product.status === 'available' ? 'Còn hàng' : product.status === 'coming_soon' ? 'Đặt hàng' : product.status === 'out_of_stock' ? 'Hết hàng' : product.status === 'discontinued' ? 'Dừng bán' : ''"></span>
                  </div>
                  <a :href="'/san-pham-chi-tiet.html?slug=' + product.slug" class="block p-4 flex-1">
                    <div class="relative overflow-hidden aspect-square mb-3 rounded-lg bg-blue-50/30">
                      <img :src="getStrapiMedia(product.images?.[0]?.url)" :alt="product.name" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-500" />
                    </div>
                    <h3 class="text-xs font-semibold text-primary line-clamp-2 leading-snug group-hover:text-accent transition-colors" x-text="product.name"></h3>
                  </a>
                  <div class="px-4 pb-4 mt-auto border-t border-blue-50 pt-2">
                    <div class="text-sm font-bold text-primary" x-text="formatPriceVND(product.price)"></div>
                    <div class="text-[10px] text-gray-400 mt-0.5" x-text="'MV: ' + formatPriceVND(product.compareAtPrice)"></div>
                  </div>
                </div>
              </template>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- BẠC MỸ NGHỆ - White Theme -->
    <section class="py-14 md:py-20 bg-white" x-data="{
      products: [],
      async init() {
        try {
          const base = window.__strapiBase || '';
          const res = await (await fetch(base + '/api/products?filters[category][name][$eq]=BẠC MỸ NGHỆ&populate=*&pagination[pageSize]=8&sort[0]=price:desc')).json();
          this.products = res.data || [];
        } catch(e) { console.error(e); }
      }
    }">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-12">
          <p class="text-primary text-sm uppercase tracking-[0.3em] mb-2">Sưu tầm & Quà tặng</p>
          <h2 class="font-heading text-3xl md:text-4xl text-primary italic">Bạc Mỹ Nghệ</h2>
          <div class="w-16 h-[2px] bg-accent mx-auto mt-4"></div>
        </div>

        <div x-show="products.length === 0" class="text-center py-10 text-gray-400">Đang tải sản phẩm...</div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
          <template x-for="product in products" :key="product.id">
            <div x-data="productCard" class="bg-white rounded-xl border border-gray-100 flex flex-col group relative hover:shadow-lg hover:border-gray-200 transition-all h-full">
              <div class="absolute top-3 left-3 z-10">
                <span class="text-[10px] px-2.5 py-1 rounded-sm font-semibold tracking-wide"
                  :class="{
                    'bg-[#E5F7ED] text-[#00A76F]': product.status === 'available' || product.status === 'coming_soon',
                    'bg-red-50 text-red-500': product.status === 'out_of_stock' || product.status === 'discontinued',
                  }"
                  x-text="product.status === 'available' ? 'Còn hàng' : product.status === 'coming_soon' ? 'Đặt hàng' : product.status === 'out_of_stock' ? 'Hết hàng' : product.status === 'discontinued' ? 'Dừng bán' : ''"></span>
              </div>

              <a :href="'/san-pham-chi-tiet.html?slug=' + product.slug" class="block p-5 flex-1">
                <div class="relative overflow-hidden aspect-square mb-4 rounded-lg bg-blue-50/30">
                  <img :src="getStrapiMedia(product.images?.[0]?.url)" :alt="product.name" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-500" />
                </div>
                <h3 class="text-xs md:text-sm font-semibold text-primary line-clamp-2 leading-snug group-hover:text-accent transition-colors" x-text="product.name"></h3>
                <p class="text-[10px] text-gray-400 mt-1" x-text="product.karatType"></p>
              </a>

              <div class="px-5 pb-5 mt-auto border-t border-gray-50 pt-3">
                <div class="flex justify-between items-end">
                  <div>
                    <div class="text-sm font-bold text-primary leading-none" x-text="formatPriceVND(product.price)"></div>
                    <div class="text-[10px] text-gray-400 mt-0.5" x-text="'MV: ' + formatPriceVND(product.compareAtPrice)"></div>
                  </div>
                  <button @click="addToCart(product)" x-show="product.status === 'available'" class="p-2.5 text-gray-300 hover:text-white bg-white hover:bg-primary border border-gray-100 hover:border-primary rounded-full transition-all" title="Thêm vào giỏ">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </template>
        </div>

        <div class="text-center mt-10">
          <a href="/san-pham-bac.html" class="inline-block border-2 border-primary text-primary px-10 py-3 rounded-full font-medium hover:bg-primary hover:text-white transition-colors text-sm uppercase tracking-wider">
            Xem tất cả Bạc mỹ nghệ
          </a>
        </div>
      </div>
    </section>

    <!-- Latest Articles -->
    <section class="py-16" x-data="{
      articles: [],
      async init() {
        try {
          const base = window.__strapiBase || '';
          const res = await (await fetch(base + '/api/articles?populate=coverImage&sort[0]=publishedDate:desc&pagination[pageSize]=3')).json();
          this.articles = res.data || [];
        } catch(e) { console.error(e); }
      }
    }">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-10">
          <h2 class="font-heading text-3xl md:text-4xl text-primary mb-2">Tin Tức & Kiến Thức</h2>
          <div class="w-20 h-1 bg-accent mx-auto"></div>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          <template x-for="a in articles" :key="a.id">
            <a :href="'/bai-viet.html?slug=' + a.slug"
              class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow group">
              <div class="aspect-video overflow-hidden">
                <img
                  :src="window.__mediaUrl(a.coverImage?.url)"
                  :alt="a.title"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="p-5">
                <div class="text-xs text-gray-400 mb-2"
                  x-text="a.publishedDate ? new Date(a.publishedDate).toLocaleDateString('vi-VN') : ''"></div>
                <h3
                  class="font-heading text-lg text-primary group-hover:text-accent transition-colors line-clamp-2 mb-2"
                  x-text="a.title"></h3>
                <p class="text-sm text-gray-600 line-clamp-3" x-text="a.excerpt"></p>
              </div>
            </a>
          </template>
        </div>
        <div class="text-center mt-10">
          <a href="/tin-tuc.html"
            class="inline-block border-2 border-primary text-primary px-8 py-3 rounded-lg font-semibold hover:bg-primary hover:text-white transition-colors">Xem
            tất cả tin tức</a>
        </div>
      </div>
    </section>

  </main>

</Layout>
