---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sản Phẩm Bạc - Vàng An Thịnh" description="Khám phá bộ sưu tập bạc tích trữ và bạc mỹ nghệ cao cấp tại Vàng An Thịnh." variant="home" showTicker={true}>

  <main x-data="silverPage" class="bg-white">

    <!-- Hero Banner -->
    <section class="max-w-[1400px] mx-auto px-4 py-4 mt-2">
      <div class="relative w-full rounded-xl overflow-hidden">
        <img src="/banner-bac.png" class="w-full h-auto" alt="Banner Bạc An Thịnh" />
      </div>
    </section>



    <!-- ==================== BẠC TÍCH TRỮ ==================== -->
    <section class="max-w-[1200px] mx-auto px-4 pb-10">
      <div class="flex items-center justify-between mb-8">
        <h2 class="font-heading text-2xl font-bold text-primary uppercase tracking-wide">Bạc tích trữ</h2>
        <span class="text-sm font-medium text-gray-500"><span x-text="tichTruProducts.length"></span> sản phẩm</span>
      </div>

      <!-- Loading -->
      <div x-show="loadingTichTru" class="text-center py-16">
        <div class="inline-block w-10 h-10 border-4 border-accent border-t-transparent rounded-full animate-spin"></div>
        <p class="mt-4 text-gray-500 font-medium">Đang tải sản phẩm...</p>
      </div>

      <!-- Grid -->
      <div x-show="!loadingTichTru && tichTruProducts.length > 0"
        class="grid grid-cols-2 lg:grid-cols-4 border-t border-l border-gray-100 bg-white">
        <template x-for="(product, index) in tichTruProducts" :key="product.id">
          <div class="group relative block border-r border-b border-gray-100 bg-white hover:shadow-[0_0_20px_rgba(0,0,0,0.08)] transition-shadow duration-300 hover:z-10 flex flex-col min-h-[420px]">
            <a :href="'/san-pham-chi-tiet.html?slug=' + product.slug" class="block flex-1 flex flex-col">
              <div class="absolute top-4 left-4 z-20">
                <span class="text-xs px-2.5 py-1 rounded-sm font-semibold tracking-wide"
                  :class="{
                    'bg-[#E5F7ED] text-[#00A76F]': product.status === 'available' || product.status === 'coming_soon',
                    'bg-red-50 text-red-500': product.status === 'out_of_stock' || product.status === 'discontinued',
                  }"
                  x-text="product.status === 'available' ? 'Còn hàng' : product.status === 'coming_soon' ? 'Đặt hàng' : product.status === 'out_of_stock' ? 'Hết hàng' : product.status === 'discontinued' ? 'Dừng bán' : ''"></span>
              </div>
              <div class="w-full pt-[100%] relative bg-gradient-to-b from-white to-[#F9F8F6]">
                <img :src="getStrapiMedia(product.images?.[0]?.url)" :alt="product.name"
                  class="absolute inset-0 m-auto w-[65%] h-[65%] object-contain drop-shadow-xl transition-all duration-500 ease-out"
                  :class="product.images?.length > 1 ? 'group-hover:opacity-0 group-hover:scale-110' : 'group-hover:scale-110'" />
                <img x-show="product.images?.length > 1" :src="getStrapiMedia(product.images?.[1]?.url)" :alt="product.name"
                  class="absolute inset-0 m-auto w-[65%] h-[65%] object-contain drop-shadow-xl opacity-0 group-hover:opacity-100 transition-all duration-500 ease-out group-hover:scale-110" />
              </div>
              <div class="p-5 flex-1 flex flex-col justify-end bg-white">
                <h3 class="text-[16px] font-bold text-primary uppercase leading-snug tracking-wide line-clamp-2 mb-[30px]" x-text="product.name"></h3>
                <div class="mt-auto">
                  <p class="text-[12px] text-[#0284c7] font-semibold uppercase mb-0.5 tracking-wider">Bán ra</p>
                  <p class="text-[22px] font-bold text-primary leading-none tracking-tight mb-2"
                    x-text="new Intl.NumberFormat('en-US').format(product.price)"></p>
                  <div class="flex items-center gap-1.5 flex-wrap">
                    <p class="text-[12px] text-pq-red font-semibold uppercase tracking-wider">Mua vào</p>
                    <p class="text-[15px] font-semibold text-pq-red tracking-tight"
                      x-text="new Intl.NumberFormat('en-US').format(product.compareAtPrice || Math.floor(product.price * 0.96))"></p>
                  </div>
                </div>
              </div>
            </a>
          </div>
        </template>
      </div>

      <!-- Pagination tich tru -->
      <div x-show="tichTruTotalPages > 1" class="flex items-center justify-center gap-1 mt-8 text-sm text-gray-500">
        <span>Hiển thị 1 - <span x-text="tichTruProducts.length"></span> trên tổng số <span x-text="tichTruTotal"></span> sản phẩm</span>
      </div>
    </section>

    <!-- Divider -->
    <div class="max-w-[1200px] mx-auto px-4"><hr class="border-gray-200 my-4" /></div>

    <!-- ==================== BẠC MỸ NGHỆ ==================== -->
    <section class="max-w-[1200px] mx-auto px-4 py-10">
      <div class="flex items-center justify-between mb-8">
        <h2 class="font-heading text-2xl font-bold text-primary uppercase tracking-wide">Bạc mỹ nghệ</h2>
        <span class="text-sm font-medium text-gray-500"><span x-text="myNgheProducts.length"></span> sản phẩm</span>
      </div>

      <!-- Loading -->
      <div x-show="loadingMyNghe" class="text-center py-16">
        <div class="inline-block w-10 h-10 border-4 border-accent border-t-transparent rounded-full animate-spin"></div>
        <p class="mt-4 text-gray-500 font-medium">Đang tải sản phẩm...</p>
      </div>

      <!-- Grid -->
      <div x-show="!loadingMyNghe && myNgheProducts.length > 0"
        class="grid grid-cols-2 lg:grid-cols-4 border-t border-l border-gray-100 bg-white">
        <template x-for="(product, index) in myNgheProducts" :key="product.id">
          <div class="group relative block border-r border-b border-gray-100 bg-white hover:shadow-[0_0_20px_rgba(0,0,0,0.08)] transition-shadow duration-300 hover:z-10 flex flex-col min-h-[420px]">
            <a :href="'/san-pham-chi-tiet.html?slug=' + product.slug" class="block flex-1 flex flex-col">
              <div class="absolute top-4 left-4 z-20">
                <span class="text-xs px-2.5 py-1 rounded-sm font-semibold tracking-wide"
                  :class="{
                    'bg-[#E5F7ED] text-[#00A76F]': product.status === 'available' || product.status === 'coming_soon',
                    'bg-red-50 text-red-500': product.status === 'out_of_stock' || product.status === 'discontinued',
                  }"
                  x-text="product.status === 'available' ? 'Còn hàng' : product.status === 'coming_soon' ? 'Đặt hàng' : product.status === 'out_of_stock' ? 'Hết hàng' : product.status === 'discontinued' ? 'Dừng bán' : ''"></span>
              </div>
              <div class="w-full pt-[100%] relative bg-gradient-to-b from-white to-[#F9F8F6]">
                <img :src="getStrapiMedia(product.images?.[0]?.url)" :alt="product.name"
                  class="absolute inset-0 m-auto w-[65%] h-[65%] object-contain drop-shadow-xl transition-all duration-500 ease-out"
                  :class="product.images?.length > 1 ? 'group-hover:opacity-0 group-hover:scale-110' : 'group-hover:scale-110'" />
                <img x-show="product.images?.length > 1" :src="getStrapiMedia(product.images?.[1]?.url)" :alt="product.name"
                  class="absolute inset-0 m-auto w-[65%] h-[65%] object-contain drop-shadow-xl opacity-0 group-hover:opacity-100 transition-all duration-500 ease-out group-hover:scale-110" />
              </div>
              <div class="p-5 flex-1 flex flex-col justify-end bg-white">
                <h3 class="text-[16px] font-bold text-primary uppercase leading-snug tracking-wide line-clamp-2 mb-[30px]" x-text="product.name"></h3>
                <div class="mt-auto">
                  <p class="text-[12px] text-[#0284c7] font-semibold uppercase mb-0.5 tracking-wider">Bán ra</p>
                  <p class="text-[22px] font-bold text-primary leading-none tracking-tight mb-2"
                    x-text="new Intl.NumberFormat('en-US').format(product.price)"></p>
                  <div class="flex items-center gap-1.5 flex-wrap">
                    <p class="text-[12px] text-pq-red font-semibold uppercase tracking-wider">Mua vào</p>
                    <p class="text-[15px] font-semibold text-pq-red tracking-tight"
                      x-text="new Intl.NumberFormat('en-US').format(product.compareAtPrice || Math.floor(product.price * 0.96))"></p>
                  </div>
                </div>
              </div>
            </a>
          </div>
        </template>
      </div>

      <!-- Pagination my nghe -->
      <div x-show="myNgheTotalPages > 1" class="flex items-center justify-center gap-1 mt-8 text-sm text-gray-500">
        <span>Hiển thị 1 - <span x-text="myNgheProducts.length"></span> trên tổng số <span x-text="myNgheTotal"></span> sản phẩm</span>
      </div>
    </section>

  </main>

</Layout>
