<!-- Search Overlay (Home variant - outside header) -->
<div x-cloak x-show="$store.ui.searchOpen" x-transition x-data="searchComponent"
  class="fixed top-0 left-0 w-full bg-white shadow-lg border-t p-4 z-[60]" style="top: auto;">
  <div class="max-w-3xl mx-auto">
    <div class="flex gap-2">
      <input type="text" x-model="query" @input="search()" @keydown.enter="goToSearch()"
        placeholder="Tìm kiếm sản phẩm..."
        class="flex-1 border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:border-accent text-sm"
        autofocus />
      <button @click="goToSearch()"
        class="bg-accent text-white px-6 py-3 rounded-lg hover:bg-accent-dark transition-colors text-sm font-medium">Tìm</button>
      <button @click="$store.ui.searchOpen = false" class="p-3 text-gray-500 hover:text-primary">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div x-show="results.length > 0" class="mt-3 border-t pt-3">
      <template x-for="item in results" :key="item.id">
        <a :href="'/san-pham-chi-tiet.html?slug=' + item.slug"
          class="flex items-center gap-3 p-2 hover:bg-light-bg rounded-lg transition-colors">
          <img :src="getStrapiMedia(item.images?.[0]?.url)" class="w-12 h-12 object-cover rounded" :alt="item.name" />
          <div>
            <div class="text-sm font-medium text-primary" x-text="item.name"></div>
            <div class="text-sm text-accent font-semibold" x-text="formatPriceVND(item.price)"></div>
          </div>
        </a>
      </template>
    </div>
  </div>
</div>
