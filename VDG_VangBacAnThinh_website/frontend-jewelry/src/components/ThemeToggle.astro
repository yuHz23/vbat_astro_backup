<!-- Floating Theme Toggle Button -->
<a id="theme-toggle" href="#"
  class="fixed bottom-6 left-6 bg-yellow-500 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg hover:bg-yellow-600 transition-colors z-40 group"
  title="Chuyển sang giao diện Vàng Bạc">
  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
      d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
  </svg>
  <span
    class="absolute left-16 bg-gray-900 text-white text-xs font-medium px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
    Giao diện Vàng Bạc
  </span>
</a>

<script is:inline>
  document.getElementById('theme-toggle').addEventListener('click', function (e) {
    e.preventDefault();
    const currentPath = window.location.pathname + window.location.search;
    window.location.href = window.location.protocol + '//' + window.location.hostname + ':3000' + currentPath;
  });
</script>
