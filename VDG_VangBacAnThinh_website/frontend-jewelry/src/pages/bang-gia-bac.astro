---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Giá Bạc Hôm Nay - Vàng An Thịnh"
  description="Bảng giá bạc An Thịnh cập nhật liên tục. Giá bạc mới nhất hôm nay."
  variant="home"
  showTicker={true}
>
  <main x-data="goldPricePage('Bạc')">

    <!-- Hero Section -->
    <section class="bg-primary text-white py-12 md:py-16 relative overflow-hidden">
      <!-- Subtle Pattern Overlay -->
      <div class="absolute inset-0 opacity-10"
        style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;">
      </div>
      <div
        class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-start md:items-end gap-6 relative z-10">
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-2.5 w-2.5 relative">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
            </span>
            <span class="text-green-200 text-sm font-semibold tracking-wide uppercase">Thị trường đang mở cửa</span>
          </div>
          <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold mb-4 tracking-tight drop-shadow-md">Giá
            Bạc Hôm Nay</h1>
          <p class="text-red-100 text-sm md:text-base font-medium">Lần cuối cập nhật: <span class="text-white font-bold"
              x-text="lastUpdated || 'Đang cập nhật...'"></span></p>
        </div>
        <button @click="fetchData()"
          class="flex items-center gap-2 border border-white/30 rounded-lg px-5 py-2.5 hover:bg-white/10 transition-colors text-sm font-semibold backdrop-blur-sm">
          <svg :class="{'animate-spin': loading}" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          Làm mới dữ liệu
        </button>
      </div>
    </section>

    <!-- Main Content Background -->
    <section class="bg-light-bg py-8 -mt-6">
      <div class="max-w-7xl mx-auto px-4 space-y-8">

        <!-- Disclaimer Banner -->
        <div
          class="bg-[#F8F6F0] border border-[#EBE5D9] rounded-xl p-4 text-sm text-gray-600 flex gap-3 items-start shadow-sm">
          <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p>
            Giá niêm yết là giá <strong>Vàng An Thịnh</strong> áp dụng trong ngày. Đơn vị: <strong>triệu
              đồng/lượng</strong> (1 lượng = 37.5g). Giá có thể thay đổi theo biến động thị trường. Liên hệ hotline
            <strong>0363.778.889</strong> để được báo giá chính xác nhất.
          </p>
        </div>



        <!-- Gold Chart Section (Full Width PhuQuy Style) -->
        <div
          class="bg-white rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.05)] border border-gray-100 p-6 md:p-8 relative z-10 w-full mb-8">
          <div
            class="flex flex-col md:flex-row justify-between md:items-center mb-6 gap-4 border-b border-gray-100 pb-6">

            <!-- Left: Title & Prices -->
            <div>
              <h2
                class="font-heading text-2xl md:text-[28px] font-bold text-gray-900 mb-3 md:mb-4 uppercase tracking-wide">
                Giá Bạc hôm nay</h2>
              <div class="flex flex-col sm:flex-row gap-4 sm:gap-8">
                <div class="flex items-baseline gap-2">
                  <span class="text-[13px] font-semibold text-gray-500 uppercase tracking-widest">MV:</span>
                  <span class="font-bold text-blue-700 text-2xl md:text-3xl tracking-tight"
                    x-text="!loadingHistories && currentSilverMV ? new Intl.NumberFormat('en-US').format(currentSilverMV) : '---'"></span>
                  <div x-show="loadingHistories" class="h-6 w-32 bg-blue-50 rounded animate-pulse absolute"></div>
                </div>
                <!-- Note: The screenshot shows BR in teal/green text. Using #00A76F -->
                <div class="flex items-baseline gap-2">
                  <span class="text-[13px] font-semibold text-gray-500 uppercase tracking-widest">BR:</span>
                  <span class="font-bold text-[#00A76F] text-2xl md:text-3xl tracking-tight"
                    x-text="!loadingHistories && currentSilverBR ? new Intl.NumberFormat('en-US').format(currentSilverBR) : '---'"></span>
                  <div x-show="loadingHistories" class="h-6 w-32 bg-green-50 rounded animate-pulse absolute"></div>
                </div>
              </div>
            </div>

            <!-- Right: Filters -->
            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 w-full md:w-auto mt-4 md:mt-0">
              <div class="relative w-full md:w-auto">
                <select x-model="selectedType"
                  class="appearance-none bg-[#F4F4F4] border-none rounded-md px-4 py-2.5 pr-10 text-[15px] font-semibold text-gray-800 focus:ring-0 cursor-pointer min-w-[220px] outline-none w-full shadow-sm">
                  <option value="Bạc">Bạc mỹ nghệ</option>
                  <option value="Bạc thỏi">Bạc thỏi</option>
                  <option value="Nhẫn tròn bạc">Nhẫn tròn trơn Bạc</option>
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-500">
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd"
                      d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                      clip-rule="evenodd" />
                  </svg>
                </div>
              </div>

              <div class="relative w-full md:w-auto">
                <select x-model="selectedTimeRange"
                  class="appearance-none bg-[#F4F4F4] border-none rounded-md px-4 py-2.5 pr-10 text-[15px] font-semibold text-gray-800 focus:ring-0 cursor-pointer min-w-[150px] outline-none w-full shadow-sm">
                  <option value="1D">1 Ngày</option>
                  <option value="7D">7 Ngày (1 Tuần)</option>
                  <option value="1M">1 Tháng</option>
                  <option value="3M">3 Tháng</option>
                  <option value="1Y">1 Năm</option>
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-500">
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd"
                      d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                      clip-rule="evenodd" />
                  </svg>
                </div>
              </div>
            </div>

          </div>

          <!-- Chart Area -->
          <div class="h-[350px] md:h-[450px] w-full relative pt-2">
            <div x-show="loadingHistories"
              class="absolute inset-0 flex items-center justify-center bg-white/80 z-20 transition-opacity">
              <svg class="w-8 h-8 animate-spin text-pq-red" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
            </div>
            <canvas id="silverChart"></canvas>
          </div>
        </div>

        <!-- Gold Price Table Card -->
        <div class="bg-white rounded-2xl shadow-lg shadow-gray-200/50 border border-gray-100 overflow-hidden">
          <div
            class="p-6 md:p-8 flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-gray-100 gap-4">
            <div>
              <h3 class="font-heading text-2xl font-bold text-gray-900 mb-2">Bảng Giá Bạc An Thịnh</h3>
              <p class="text-sm text-gray-500 mt-1">Niêm yết công khai & minh bạch</p>
            </div>
            <div
              class="text-xs font-bold text-red-600 bg-red-50 border border-red-100 px-4 py-2 rounded-lg flex items-center gap-2 shadow-sm">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              Quản trị viên (Nhấn vào nút Sửa bên dưới)
            </div>
          </div>

          <!-- Loading State -->
          <div x-show="loading" class="text-center py-20 px-4">
            <svg class="w-10 h-10 mx-auto mb-4 animate-spin text-pq-red" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <p class="text-gray-600 font-medium">Đang đồng bộ dữ liệu thị trường từ hệ thống...</p>
          </div>

          <!-- Table -->
          <div x-show="!loading" class="overflow-x-auto" x-cloak>
            <table class="w-full text-left border-collapse min-w-[700px]">
              <thead>
                <tr
                  class="bg-gray-50/80 border-b border-gray-100 text-gray-500 text-xs font-bold uppercase tracking-wider backdrop-blur-sm">
                  <th class="py-5 px-6 md:px-8">Sản phẩm / Loại vàng</th>
                  <th class="py-5 px-6 md:px-8 text-right">Mua vào</th>
                  <th class="py-5 px-6 md:px-8 text-right">Bán ra</th>
                  <th class="py-5 px-6 md:px-8 text-right">Chênh lệch</th>
                  <th class="py-5 px-6 md:px-8 text-center w-24">Thao tác</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <!-- GOLD SECTION -->
                <tr class="bg-gray-100/50">
                  <td colspan="5"
                    class="py-3 px-6 md:px-8 font-bold text-primary uppercase tracking-wider text-sm italic">Dữ liệu Giá
                    Vàng</td>
                </tr>
                <template x-for="price in goldPrices" :key="'gold-' + price.id">
                  <tr class="hover:bg-blue-50/40 transition-colors group">
                    <td class="py-5 px-6 md:px-8">
                      <div class="font-bold text-gray-900 text-base mb-1" x-text="price.goldName"></div>
                      <div class="text-[13px] text-gray-500 font-medium"
                        x-text="'Mã: ' + price.goldType + ' • ' + price.unit"></div>
                    </td>
                    <td class="py-5 px-6 md:px-8 text-right">
                      <div class="font-bold text-gray-900 text-lg tabular-nums" x-text="formatPriceVND(price.buyPrice)">
                      </div>
                    </td>
                    <td class="py-5 px-6 md:px-8 text-right">
                      <div class="font-bold text-gray-900 text-lg tabular-nums"
                        x-text="formatPriceVND(price.sellPrice)"></div>
                    </td>
                    <td class="py-5 px-6 md:px-8 text-right">
                      <div class="font-semibold text-gray-400 text-sm tabular-nums flex items-center justify-end gap-1">
                        <span x-text="formatPriceVND(price.sellPrice - price.buyPrice)"></span>
                        <svg class="w-3 h-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                        </svg>
                      </div>
                    </td>
                    <td class="py-5 px-6 md:px-8 text-center">
                      <button @click="openEditModal(price)"
                        class="text-gray-400 hover:text-white border border-transparent hover:border-pq-red hover:bg-pq-red p-2 rounded transition-all shadow-sm opacity-50 group-hover:opacity-100"
                        title="Chỉnh sửa giá">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                        </svg>
                      </button>
                    </td>
                  </tr>
                </template>

                <!-- SILVER SECTION -->
                <tr class="bg-gray-100/50">
                  <td colspan="5"
                    class="py-3 px-6 md:px-8 font-bold text-gray-900 uppercase tracking-wider text-sm italic">Dữ liệu
                    Giá Bạc</td>
                </tr>
                <template x-for="price in silverPrices" :key="'silver-' + price.id">
                  <tr class="hover:bg-blue-50/40 transition-colors group">
                    <td class="py-5 px-6 md:px-8">
                      <div class="font-bold text-gray-900 text-base mb-1" x-text="price.goldName"></div>
                      <div class="text-[13px] text-gray-500 font-medium"
                        x-text="'Mã: ' + price.goldType + ' • ' + price.unit"></div>
                    </td>
                    <td class="py-5 px-6 md:px-8 text-right">
                      <div class="font-bold text-gray-900 text-lg tabular-nums" x-text="formatPriceVND(price.buyPrice)">
                      </div>
                    </td>
                    <td class="py-5 px-6 md:px-8 text-right">
                      <div class="font-bold text-gray-900 text-lg tabular-nums"
                        x-text="formatPriceVND(price.sellPrice)"></div>
                    </td>
                    <td class="py-5 px-6 md:px-8 text-right">
                      <div class="font-semibold text-gray-400 text-sm tabular-nums flex items-center justify-end gap-1">
                        <span x-text="formatPriceVND(price.sellPrice - price.buyPrice)"></span>
                        <svg class="w-3 h-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                        </svg>
                      </div>
                    </td>
                    <td class="py-5 px-6 md:px-8 text-center">
                      <button @click="openEditModal(price)"
                        class="text-gray-400 hover:text-white border border-transparent hover:border-pq-red hover:bg-pq-red p-2 rounded transition-all shadow-sm opacity-50 group-hover:opacity-100"
                        title="Chỉnh sửa giá">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                        </svg>
                      </button>
                    </td>
                  </tr>
                </template>

                <tr x-show="goldPrices.length === 0 && silverPrices.length === 0" x-cloak>
                  <td colspan="5" class="py-20 text-center">
                    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 mb-4">
                      <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                      </svg>
                    </div>
                    <p class="text-gray-500 font-medium">Chưa có dữ liệu giá trong hệ thống.</p>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>



      </div>
    </section>

  </main>
</Layout>
