---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hệ Thống Cửa Hàng - Vàng An Thịnh" description="Hệ thống cửa hàng Vàng An Thịnh - Địa chỉ mua bán vàng bạc uy tín tại Hà Nội." variant="home" showTicker={true}>
  <main x-data="storeLocator">

    <!-- Breadcrumb -->
    <div class="bg-white border-b">
      <div class="max-w-7xl mx-auto px-4 py-3">
        <nav class="text-sm text-gray-500">
          <a href="/" class="hover:text-accent">Trang chủ</a>
          <span class="mx-2">/</span>
          <span class="text-primary font-medium">Hệ thống cửa hàng</span>
        </nav>
      </div>
    </div>

    <!-- Page Header -->
    <section class="bg-primary py-12">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h1 class="font-heading text-3xl md:text-4xl text-accent mb-3">Hệ Thống Cửa Hàng</h1>
        <p class="text-text-light text-lg">Tìm cửa hàng Vàng An Thịnh gần bạn nhất</p>
      </div>
    </section>

    <!-- Store List + Map -->
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4">
        <div class="grid lg:grid-cols-2 gap-8">

          <!-- Store List -->
          <div>
            <h2 class="font-heading text-2xl text-primary mb-6">Danh Sách Cửa Hàng</h2>

            <div x-show="loading" class="text-center py-10 text-gray-500">Đang tải danh sách cửa hàng...</div>

            <div x-show="!loading && stores.length === 0" class="text-center py-10 text-gray-500">
              <p>Chưa có thông tin cửa hàng.</p>
            </div>

            <div class="space-y-4">
              <template x-for="store in stores" :key="store.id">
                <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow border border-gray-100">
                  <h3 class="font-heading text-lg text-primary mb-3" x-text="store.name"></h3>
                  <div class="space-y-2 text-sm text-gray-600">
                    <div class="flex items-start gap-2">
                      <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor"
                        viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      <span x-text="store.address"></span>
                    </div>
                    <div class="flex items-center gap-2">
                      <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor"
                        viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                      </svg>
                      <a :href="'tel:' + store.phone" class="text-accent hover:text-accent-dark font-medium"
                        x-text="store.phone"></a>
                    </div>
                    <div x-show="store.openingHours" class="flex items-center gap-2">
                      <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor"
                        viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span x-text="store.openingHours"></span>
                    </div>
                  </div>
                </div>
              </template>
            </div>

            <!-- Default store if API returns nothing -->
            <div x-show="!loading && stores.length === 0"
              class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 mt-4">
              <h3 class="font-heading text-lg text-primary mb-3">Vàng An Thịnh - Trương Định</h3>
              <div class="space-y-2 text-sm text-gray-600">
                <div class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor"
                    viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span>Số 141P Trương Định, Phường Tương Mai, Quận Hoàng Mai, Hà Nội</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <a href="tel:0363778889" class="text-accent hover:text-accent-dark font-medium">0363 778 889</a>
                </div>
                <div class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>8:00 - 20:00 (Thứ 2 - Chủ nhật)</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Map Embed -->
          <div class="h-full flex flex-col">
            <h2 class="font-heading text-2xl text-primary mb-6">Bản Đồ</h2>
            <div
              class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden aspect-square lg:aspect-auto flex-1 min-h-[400px]">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3725.109315082156!2d105.84576301540188!3d20.98825228602058!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3135ac5df93a201b%3A0x6bba41a37cdec377!2zMTQxUCBQLiBUcsawxqFuZyDEkOG7i25oLCBUxrDGoW5nIE1haSwgSG_DoG5nIE1haSwgSMOgIE7hu5lpLCBWaWV0bmFt!5e0!3m2!1sen!2s!4v1684307524953!5m2!1sen!2s"
                width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
                referrerpolicy="no-referrer-when-downgrade">
              </iframe>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>
</Layout>
