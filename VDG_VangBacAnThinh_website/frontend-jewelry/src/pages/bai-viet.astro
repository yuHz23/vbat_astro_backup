---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout title="Bài viết - Vàng An Thịnh" description="Bài viết chi tiết từ Vàng An Thịnh." variant="inner" showTicker={false}>

  <main x-data="{
    article: null,
    loading: true,
    async init() {
      const params = new URLSearchParams(window.location.search);
      const slug = params.get('slug');
      if (!slug) { this.loading = false; return; }
      try {
        const res = await (await fetch('/api/articles?filters[slug][$eq]=' + encodeURIComponent(slug) + '&populate=coverImage,articleCategory')).json();
        this.article = res.data?.[0] || null;
        if (this.article) {
          document.title = this.article.title + ' - Vàng An Thịnh';
        }
      } catch(e) { console.error(e); }
      finally { this.loading = false; }
    }
  }">

    <!-- Breadcrumb -->
    <div class="bg-white border-b">
      <div class="max-w-7xl mx-auto px-4 py-3">
        <nav class="text-sm text-gray-500">
          <a href="/" class="hover:text-accent">Trang chủ</a>
          <span class="mx-2">/</span>
          <a href="/tin-tuc.html" class="hover:text-accent">Tin tức</a>
          <span class="mx-2">/</span>
          <span class="text-primary font-medium" x-text="article?.title || 'Bài viết'"></span>
        </nav>
      </div>
    </div>

    <!-- Loading -->
    <div x-show="loading" class="text-center py-20 text-gray-500">Đang tải bài viết...</div>

    <!-- Not Found -->
    <div x-show="!loading && !article" class="text-center py-20">
      <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <h2 class="text-xl font-heading text-primary mb-2">Không tìm thấy bài viết</h2>
      <a href="/tin-tuc.html" class="text-accent hover:underline">Quay lại trang tin tức</a>
    </div>

    <!-- Article Content -->
    <article x-show="!loading && article" class="py-12">
      <div class="max-w-4xl mx-auto px-4">
        <!-- Cover Image -->
        <div class="aspect-video rounded-xl overflow-hidden mb-8">
          <img
            :src="article?.coverImage?.url ? (article.coverImage.url.startsWith('http') ? article.coverImage.url : 'http://localhost:1337' + article.coverImage.url) : '/placeholder.jpg'"
            :alt="article?.title"
            class="w-full h-full object-cover"
          />
        </div>

        <!-- Meta -->
        <div class="flex items-center gap-4 mb-6">
          <span x-show="article?.articleCategory" class="text-sm bg-accent/10 text-accent px-3 py-1 rounded-full font-medium" x-text="article?.articleCategory?.name"></span>
          <span class="text-sm text-gray-400" x-text="article?.publishedDate ? new Date(article.publishedDate).toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' }) : ''"></span>
        </div>

        <!-- Title -->
        <h1 class="font-heading text-3xl md:text-4xl text-primary mb-8 leading-tight" x-text="article?.title"></h1>

        <!-- Content -->
        <div class="prose prose-lg max-w-none text-text-dark leading-relaxed
          [&_h2]:font-heading [&_h2]:text-primary [&_h2]:text-2xl [&_h2]:mt-10 [&_h2]:mb-4
          [&_h3]:font-heading [&_h3]:text-primary [&_h3]:text-xl [&_h3]:mt-8 [&_h3]:mb-3
          [&_p]:mb-4 [&_p]:text-gray-700
          [&_a]:text-accent [&_a]:underline
          [&_img]:rounded-lg [&_img]:my-6
          [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4
          [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-4
          [&_blockquote]:border-l-4 [&_blockquote]:border-accent [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-gray-600
        " x-html="article?.content"></div>

        <!-- Back link -->
        <div class="mt-12 pt-8 border-t">
          <a href="/tin-tuc.html" class="inline-flex items-center gap-2 text-accent hover:text-accent-dark font-medium">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Quay lại trang tin tức
          </a>
        </div>
      </div>
    </article>

  </main>

</Layout>
